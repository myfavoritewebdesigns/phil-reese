---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_URL, SITE_NAME, LEGAL_NAME, contact, socialSameAs } from "../config/site";

interface Props {
  title?:           string;
  description?:     string;
  canonical?:       string;
  ogImage?:         string;
  ogImageAlt?:      string;
  ogImageWidth?:    number;
  ogImageHeight?:   number;
  ogType?:          "website" | "article" | "product" | "profile";
  noIndex?:         boolean;
  structuredData?:  Record<string, unknown> | Record<string, unknown>[];
  modifiedTime?:    string;
  publishedTime?:   string;
}

const {
  title = `${SITE_NAME}`,
  description = "TODO: default site description.",
  canonical,
  ogImage = `${SITE_URL}/images/og-default.jpg`,
  ogImageAlt = `${SITE_NAME}`,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogType = "website",
  noIndex = false,
  structuredData,
  modifiedTime,
  publishedTime,
} = Astro.props;

const canonicalUrl = canonical
  ? (canonical.startsWith("http") ? canonical : `${SITE_URL}${canonical}`)
  : `${SITE_URL}${Astro.url.pathname}`;

// Global publisher entity — appears on every page as the `@id` that
// WebSite.publisher and (homepage) Person.worksFor reference.
// Typed `Organization`, NOT `LocalBusiness`: the live site emits no global
// business node — its only local-business schema is the standalone
// FinancialService office graph (per page). Typing this `LocalBusiness` made
// Google's Rich Results "Local businesses" report count it as a duplicate
// listing of the FinancialService #SouthPhoenix node. Organization is not a
// LocalBusiness subtype, so it's a valid publisher without being double-counted.
const orgSchema = {
  "@type": "Organization",
  "@id": `${SITE_URL}/`,
  url: `${SITE_URL}/`,
  sameAs: [...socialSameAs],
  name: LEGAL_NAME,
  telephone: contact.telDashed,
  email: contact.email,
  address: {
    "@type": "PostalAddress",
    streetAddress:   contact.address.street,
    addressLocality: contact.address.city,
    addressRegion:   contact.address.region,
    postalCode:      contact.address.postalCode,
    addressCountry:  contact.address.country,
  },
};

const siteSchema = {
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  url: `${SITE_URL}/`,
  name: SITE_NAME,
  publisher: { "@id": `${SITE_URL}/` },
  // Live (Yoast) emits a SearchAction on every page's WebSite node — kept for
  // JSON-LD parity (live-diff audit checks @type presence).
  potentialAction: [
    {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${SITE_URL}/?s={search_term_string}`,
      },
      "query-input": {
        "@type": "PropertyValueSpecification",
        valueRequired: true,
        valueName: "search_term_string",
      },
    },
  ],
  inLanguage: "en-US",
};

// Emit the global schemas Yoast-style — one script with an @graph (matches
// how the live WP site structures its sitewide schema).
const globalSchemaGraph: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@graph": [orgSchema, siteSchema],
};

const allSchemas: Record<string, unknown>[] = [globalSchemaGraph];
if (structuredData) {
  if (Array.isArray(structuredData)) allSchemas.push(...structuredData);
  else allSchemas.push(structuredData);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" />
    }
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon — add /images/favicon.png to public/images/ -->
    <link rel="icon" href="/images/favicon.png" type="image/png" />

    <!-- Preload primary display font (live site preloads CrimsonText-Regular) -->
    <link rel="preload" href="/fonts/CrimsonText-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:locale"            content="en_US" />
    <meta property="og:type"              content={ogType} />
    <meta property="og:title"             content={title} />
    <meta property="og:description"       content={description} />
    <meta property="og:url"               content={canonicalUrl} />
    <meta property="og:site_name"         content={SITE_NAME} />
    <meta property="og:image"             content={ogImage} />
    <meta property="og:image:secure_url"  content={ogImage} />
    <meta property="og:image:width"       content={String(ogImageWidth)} />
    <meta property="og:image:height"      content={String(ogImageHeight)} />
    <meta property="og:image:alt"         content={ogImageAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime  && <meta property="article:modified_time"  content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- JSON-LD -->
    {allSchemas.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Page-level <head> injections: rel=prev/next on paginated archives, hreflang, etc. -->
    <slot name="head" />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Shared contact form handler — wires to /api/contact (CF Pages Function) -->
    <script src="../scripts/contact-form.ts"></script>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: 8px;
    top: -40px;
    z-index: 100;
    padding: 8px 16px;
    background: var(--color-brand-primary-dark, #682412);
    color: #fff;
    font-family: var(--font-display, sans-serif);
    font-weight: 600;
    text-decoration: none;
    border-radius: 0 0 4px 4px;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 0;
    outline: 3px solid var(--color-brand-gold, #c8983a);
  }
</style>
