---
/**
 * Pagination control for /blog/, /category/X/, /tag/X/, /author/X/.
 * Renders Prev / Next plus numbered page links. Mirrors WP's default theme
 * behavior so existing internal links from "Older posts" widgets still match.
 *
 * For the SEO half (rel=prev/next in <head>), the listing page injects those
 * separately via the canonical/head slot in Layout.astro.
 */

interface Props {
  /** Current page number, 1-indexed. */
  currentPage: number;
  /** Total pages in the paginated set. */
  totalPages: number;
  /** URL of the previous page, undefined if currentPage === 1. */
  prevUrl?: string;
  /** URL of the next page, undefined if currentPage === totalPages. */
  nextUrl?: string;
  /** Archive root, e.g. "/blog" or "/category/news". Used to build numbered links. */
  basePath: string;
}

const { currentPage, totalPages, prevUrl, nextUrl, basePath } = Astro.props;
const base = basePath.replace(/\/+$/, "");

if (totalPages <= 1) {
  // Single-page archive — nothing to render.
}

function pageHref(n: number): string {
  return n <= 1 ? `${base}/` : `${base}/page/${n}/`;
}

// Build a compact numbered range: first, last, current, current±1, with ellipsis gaps.
function windowedPages(current: number, total: number): (number | "…")[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const out: (number | "…")[] = [1];
  if (current > 3) out.push("…");
  for (let n = Math.max(2, current - 1); n <= Math.min(total - 1, current + 1); n++) {
    out.push(n);
  }
  if (current < total - 2) out.push("…");
  out.push(total);
  return out;
}

const pageNumbers = windowedPages(currentPage, totalPages);
---

{totalPages > 1 && (
  <nav class="site-pagination" aria-label="Pagination">
    {prevUrl ? (
      <a href={prevUrl} class="site-pagination__prev" rel="prev">
        <span aria-hidden="true">←</span> Previous
      </a>
    ) : (
      <span class="site-pagination__prev site-pagination__prev--disabled" aria-hidden="true">
        <span>←</span> Previous
      </span>
    )}

    <ol class="site-pagination__pages">
      {pageNumbers.map((p) => (
        <li>
          {p === "…" ? (
            <span class="site-pagination__ellipsis" aria-hidden="true">…</span>
          ) : p === currentPage ? (
            <span class="site-pagination__current" aria-current="page">{p}</span>
          ) : (
            <a href={pageHref(p)}>{p}</a>
          )}
        </li>
      ))}
    </ol>

    {nextUrl ? (
      <a href={nextUrl} class="site-pagination__next" rel="next">
        Next <span aria-hidden="true">→</span>
      </a>
    ) : (
      <span class="site-pagination__next site-pagination__next--disabled" aria-hidden="true">
        Next <span>→</span>
      </span>
    )}
  </nav>
)}

<style>
  .site-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin: 3rem 0 1rem;
    flex-wrap: wrap;
  }
  .site-pagination__prev,
  .site-pagination__next {
    color: var(--color-brand-primary, #682412);
    text-decoration: none;
    font-weight: 600;
  }
  .site-pagination__prev:hover,
  .site-pagination__next:hover { text-decoration: underline; }
  .site-pagination__prev--disabled,
  .site-pagination__next--disabled {
    color: var(--color-muted-text, #b0b0b0);
    cursor: default;
  }
  .site-pagination__pages {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }
  .site-pagination__pages li a,
  .site-pagination__current,
  .site-pagination__ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-body, #333);
  }
  .site-pagination__pages li a:hover {
    background: var(--color-muted, #f4f4f4);
  }
  .site-pagination__current {
    background: var(--color-brand-primary, #682412);
    color: #fff;
  }
  .site-pagination__ellipsis {
    color: var(--color-muted-text, #6b6b6b);
  }
</style>
