---
import type { BlogPost } from "../../lib/blog";
import { formatDate } from "../../lib/blog";

interface Props {
  post: BlogPost;
  /** Heading level for the card title — H2 on listing pages, H3 if nested inside another section. */
  headingLevel?: 2 | 3;
}

const { post, headingLevel = 2 } = Astro.props;
const { title, description, pubDate, featuredImage, author } = post.data;
const href = `/blog/${post.id}/`;
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<article class="site-blogcard">
  {featuredImage && (
    <a href={href} class="site-blogcard__thumb" aria-hidden="true" tabindex="-1">
      <img
        src={featuredImage.src}
        alt={featuredImage.alt}
        width={featuredImage.width ?? 800}
        height={featuredImage.height ?? 450}
        loading="lazy"
        decoding="async"
      />
    </a>
  )}

  <div class="site-blogcard__body">
    <Heading class="site-blogcard__title">
      <a href={href}>{title}</a>
    </Heading>

    <p class="site-blogcard__meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      {author?.name && (
        <>
          {" "}by{" "}
          <a href={`/author/${author.slug}/`} rel="author">{author.name}</a>
        </>
      )}
    </p>

    <p class="site-blogcard__desc">{description}</p>

    <a href={href} class="site-blogcard__more">
      Read more <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .site-blogcard {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: #fff;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .site-blogcard:hover {
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .site-blogcard__thumb {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-muted, #f4f4f4);
  }
  .site-blogcard__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .site-blogcard__body {
    padding: 1.25rem 1.5rem 1.5rem;
  }
  .site-blogcard__title {
    margin: 0 0 0.5rem;
    font-size: 1.375rem;
    line-height: 1.25;
  }
  .site-blogcard__title a {
    color: inherit;
    text-decoration: none;
  }
  .site-blogcard__title a:hover { text-decoration: underline; }
  .site-blogcard__meta {
    color: var(--color-muted-text, #6b6b6b);
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
  }
  .site-blogcard__meta a { color: inherit; }
  .site-blogcard__desc {
    margin: 0 0 1rem;
    color: var(--color-body, #333);
    line-height: 1.55;
  }
  .site-blogcard__more {
    font-weight: 600;
    text-decoration: none;
    color: var(--color-brand-primary, #682412);
  }
  .site-blogcard__more:hover { text-decoration: underline; }
</style>
