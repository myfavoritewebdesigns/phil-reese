---
/* -----------------------------------------------------------------------
   Arizona Business Broker (test) — rebuild of the live Elementor "canvas"
   landing page
     https://www.philsellsbiz.com/arizona-business-broker-test/
   (recovered from the Wayback Machine snapshot 2026-03-06; the live origin
   is being decommissioned).

   The live page is a standalone Elementor *canvas* template: it renders its
   OWN header-nav + footer rather than the theme chrome. Per CLAUDE.md rule
   #13 every page must extend Layout.astro, so the rebuild drops the page's
   embedded (and redundant) header/footer/YARPP-related-posts and renders the
   distinctive BODY content inside the standard site Header/Footer. Copy is
   verbatim from the snapshot; styling uses the shared city-page section
   vocabulary + design tokens (landing-page "close enough" fidelity bar,
   Decision log 2026-06).

   Live page is `noindex, follow` (it was a test page) — preserved via
   noIndex so we don't surface a duplicate of /phoenix-business-broker/.

   Sections in DOM order:
     1. banner-sctn       — H1 + banner image + WARNING! + CTA button
     2. valuation-sctn    — "Get Your Free No-Obligation Valuation" + form
     3. why-sctn          — "Why Choose Phil Reese?" 5 reason cards + phone CTA
     4. video-aalt-sctn   — "Your Arizona Business Broker" + video (_hXlR94431c)
     5. cbi-info-section  — "WHAT IS A CBI?" copy + button + video (CQp4Vt6o8Js)
   ----------------------------------------------------------------------- */
import Layout from "../layouts/Layout.astro";
import { SITE_URL, contact, hrefs, replyMethods } from "../config/site";
import financialServiceSchema from "../../reference/home-financialservice-schema.json";

/* Live <title> + meta description, verbatim from the snapshot. */
const pageTitle = "Phoenix Business Broker | Phil Reese Sells Arizona Businesses";
const pageDescription =
  "Call Arizona Business Broker Phil Reese When You Are Ready to Sell Your Business!";

const IMG = "/images/arizona-business-broker-test";
const ogImage = `${SITE_URL}${IMG}/top-banne-bg-3.jpg`;

/* Minimal page schema (Layout injects Organization + WebSite). FinancialService
   replicated for local-business eligibility, consistent with the city pages. */
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${SITE_URL}/arizona-business-broker-test/`,
  url: `${SITE_URL}/arizona-business-broker-test/`,
  name: pageTitle,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  description: pageDescription,
  inLanguage: "en-US",
};

const structuredData = [
  { "@context": "https://schema.org", "@graph": [webPageSchema] },
  financialServiceSchema,
];

/* ---------- "Why Choose Phil Reese?" reason cards (verbatim copy) ---------- */
const reasons = [
  {
    img: "Former-business-owner.png",
    w: 81, h: 81,
    alt: "Former Business Owner",
    title: "Former Business Owner",
    body: "As a former business owner himself, who sold one of his businesses through a Business Broker, Phil has unique insights into buying and selling businesses in Arizona that most other Business Brokers don’t have. This makes all the difference in the world when looking for a smooth and profitable business selling transaction. With help from Phil, he can provide the skills and expertise you need in order to negotiate the successful sale of your business.",
  },
  {
    img: "why-chose-us-02.png",
    w: 76, h: 81,
    alt: "Certified Business Intermediary",
    title: "Certified Business Intermediary",
    body: "Phil is a Certified Business Intermediary (CBI) which means you’ll have chosen a proven professional. Through this prestigious designation, a Certified Business Intermediary has proven their skill, professionalism, and knowledge through continuing education and exemplary practices within the Business Broker industry.",
    cta: { label: "What is CBI", href: "/what-is-a-cbi/" },
  },
  {
    img: "20-years-2.png",
    w: 83, h: 78,
    alt: "Over 20 Years Experience",
    title: "Over 20 Years Experience",
    body: "Phil has been helping people sell their businesses for over 20 years. Having an experienced competent Business Broker on your side is the only way to make sure every detail of selling your business is taken care of. Phil will make sure each and every one of your questions or concerns are answered and can make the process of transferring ownership of your business as smooth and painless as possible.",
  },
  {
    img: "why-chose-us-04.png",
    w: 76, h: 81,
    alt: "Free No-Obligation Valuations",
    title: "Free No-Obligation Valuations",
    body: "Phil can provide a Free No-Obligation valuation of your business to determine its current value. He can help you understand the valuation process and can come up with a realistic price for your business when you are ready to sell. Through a strategic marketing process, he can find the right buyers for you and sell your business for top dollar!",
  },
  {
    img: "why-chose-us-05.png",
    w: 76, h: 81,
    alt: "5 Star Reviews & BBB A+ Rated",
    title: "5 Star Reviews & BBB A+ Rated",
    body: "With over 20 years of experience as a Business Broker, Phil is an industry leader in business sales and has more testimonials than any other Business Broker in town. He has earned an A+ rating with the Better Business Bureau, has many 5 Star Google reviews and can effectively market your business to potential buyers and provide you with a seamless business transaction.",
    cta: { label: "More Testimonials", href: "/testimonials/" },
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/arizona-business-broker-test/"
  ogImage={ogImage}
  ogImageAlt="Phil Reese, Certified Business Intermediary"
  ogImageWidth={1213}
  ogImageHeight={291}
  noIndex={true}
  structuredData={structuredData}
>
  <!-- lite-youtube web component — replaces the live Elementor lazy YouTube embeds. -->
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.css"
  />
  <script
    slot="head"
    is:inline
    src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.js"
    defer></script>

  <!-- 1. banner-sctn — hero: heading + banner image + WARNING + CTA -->
  <section class="section banner-sctn">
    <div class="section-wrap">
      <div class="one-col">
        <h1 class="maintitle h3-style">Call Arizona Business Broker Phil Reese<br />When You Are Ready to Sell Your Business!</h1>
        <img
          src={`${IMG}/top-banne-bg-3.jpg`}
          alt="Phil Reese, Certified Business Intermediary"
          width="1213"
          height="291"
          class="banner-img"
          fetchpriority="high"
        />
        <h2 class="warn h3-style">WARNING!</h2>
        <p class="warn-sub">Before You Decide To Sell Your Business<br />There Are Many Vital Things you Need To Know.</p>
        <a class="warn-btn" href="/business-sellers/">Click here!</a>
      </div>
    </div>
  </section>

  <!-- 2. valuation-sctn — "Get Your Free No-Obligation Valuation" + contact form -->
  <section class="section valuation-sctn">
    <div class="section-wrap">
      <div class="one-col">
        <h2 class="maintitle h3-style">Get Your Free No-Obligation Valuation</h2>
        <div class="wpcf7">
          <form
            class="wpcf7-form"
            action="/api/contact"
            method="post"
            aria-label="Contact form"
            data-pr-contact-form
            data-form-id="arizona-test"
          >
            <input type="text" name="_honeypot" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="pr-hp" />
            <div class="bottom-form">
              <div class="col-1">
                <label for="your-name-bt">Name</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="text" name="your-name-bt" id="your-name-bt" class="wpcf7-form-control wpcf7-text" maxlength="400" placeholder="Name*" required aria-required="true" />
                </span>
              </div>
              <div class="col-2">
                <label for="your-email-bt">Email</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="email" name="your-email-bt" id="your-email-bt" class="wpcf7-form-control wpcf7-email wpcf7-text" maxlength="400" placeholder="Email*" required aria-required="true" />
                </span>
              </div>
              <div class="col-3">
                <label for="your-phone-bt">Phone</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="tel" name="your-phone-bt" id="your-phone-bt" class="wpcf7-form-control wpcf7-tel wpcf7-text" maxlength="400" placeholder="Phone*" required aria-required="true" />
                </span>
              </div>
              <div class="col-4">
                <label for="your-message-bt">Comments</label>
                <span class="wpcf7-form-control-wrap">
                  <textarea name="your-message-bt" id="your-message-bt" class="wpcf7-form-control wpcf7-textarea" cols="40" rows="10" maxlength="2000" minlength="20" placeholder="Comments*" required aria-required="true"></textarea>
                </span>
              </div>
              <div class="col-5">
                <div class="bst-way">
                  <label>Best Way to Reply:</label>
                  <span class="wpcf7-form-control-wrap">
                    <span class="wpcf7-form-control wpcf7-radio">
                      {replyMethods.map((method, i) => (
                        <span class={`wpcf7-list-item${i === 0 ? " first" : ""}${i === replyMethods.length - 1 ? " last" : ""}`}>
                          <label>
                            <input type="radio" name="bst-way-bt" value={method} checked={i === 0} />
                            <span class="wpcf7-list-item-label">{method}</span>
                          </label>
                        </span>
                      ))}
                    </span>
                  </span>
                </div>
                <button type="submit" class="wpcf7-form-control wpcf7-submit">Send</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. why-sctn — "Why Choose Phil Reese?" reason cards + phone CTA -->
  <section class="section why-sctn">
    <div class="section-wrap">
      <div class="why-title">
        <h2 class="h3-style">Why Choose <span>Phil Reese?</span></h2>
      </div>
      <div class="why-grid">
        {reasons.map((r) => (
          <div class="why-card">
            <div class="why-icon">
              <img src={`${IMG}/${r.img}`} alt={r.alt} width={r.w} height={r.h} loading="lazy" />
            </div>
            <h3 class="h5-style">{r.title}</h3>
            <p>{r.body}</p>
            {r.cta && <a class="why-cta" href={r.cta.href}>{r.cta.label}</a>}
          </div>
        ))}
      </div>
      <div class="why-phone">
        <a href={hrefs.tel} class="phone-cta">
          <svg aria-hidden="true" viewBox="0 0 512 512"><path d="M497.39 361.8l-112-48a24 24 0 0 0-28 6.9l-49.6 60.6A370.66 370.66 0 0 1 130.6 204.11l60.6-49.6a23.94 23.94 0 0 0 6.9-28l-48-112A24.16 24.16 0 0 0 122.6.61l-104 24A24 24 0 0 0 0 48c0 256.5 207.9 464 464 464a24 24 0 0 0 23.4-18.6l24-104a24.29 24.29 0 0 0-14.01-27.6z"></path></svg>
          {contact.phoneDashed}
        </a>
      </div>
    </div>
  </section>

  <!-- 4. video-aalt-sctn — "Your Arizona Business Broker" + video -->
  <section class="section video-aalt-sctn">
    <div class="section-wrap">
      <div class="title-col">
        <h2 class="tc h3-style">Your Arizona <span>Business Broker</span></h2>
        <h3 class="tc h5-style">Sell Confidentially &amp; Get Maximum Results</h3>
      </div>
      <div class="img-col">
        <div class="lyte-wrapper" title="Your Arizona Business Broker">
          <lite-youtube
            videoid="_hXlR94431c"
            title="Your Arizona Business Broker"
            style={`background-image:url('${IMG}/yt-_hXlR94431c.jpg');`}
          >
            <a href="https://youtu.be/_hXlR94431c" class="lite-yt-fallback" rel="nofollow">Watch this video on YouTube</a>
          </lite-youtube>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. cbi-info-section — "WHAT IS A CBI?" copy + button + video -->
  <section class="section cbi-info-section">
    <div class="section-wrap">
      <div class="cbi-head">
        <h2 class="h3-style"><span>WHAT IS A CBI?</span></h2>
        <h3 class="h5-style">Why You Should Only Hire a Certified Business Intermediary<br />To Sell Your Arizona Business</h3>
      </div>
      <div class="cbi-cols">
        <div class="cbi-text">
          <p>The International Business Brokers Association (IBBA), which is the largest Business Broker trade group in the World, awards the Certified Business Intermediary (CBI) designation to Business Brokers who successfully complete educational classes and tests to prove they are competent to facilitate the sale of businesses. It takes a lot of time and effort to attain the CBI designation. Phil had to travel around the country to attend conferences put on by the IBBA to get the necessary education. He spent several days in grueling, intense, mentally taxing classes on how to be the best of the best when it comes to assisting business owners in the transfer and marketing of their companies when they are ready to sell. He had to take a total of 60 hours of classes, with a test at the end of each class, in order to qualify for the final exam.</p>
          <a class="cbi-btn" href="/what-is-a-cbi/">What is CBI?</a>
        </div>
        <div class="cbi-video">
          <div class="lyte-wrapper" title="Thinking of Selling or Buying a Business?">
            <lite-youtube
              videoid="CQp4Vt6o8Js"
              title="Thinking of Selling or Buying a Business?"
              style="background-image:url('/images/what-is-a-cbi/yt-CQp4Vt6o8Js.jpg');"
            >
              <a href="https://youtu.be/CQp4Vt6o8Js" class="lite-yt-fallback" rel="nofollow">Watch this video on YouTube</a>
            </lite-youtube>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<!-- Section CSS — shared city-page vocabulary + page-specific layout.
     is:global so the .wpcf7 form + lite-youtube nodes are matched. -->
<style is:global>
  /* ---------- 1. banner-sctn ---------- */
  .banner-sctn { padding-top: 70px; padding-bottom: 70px; background: #f9f9f9; box-shadow: 0 0 15px 0 rgba(0,0,0,.25); z-index: 1; text-align: center; }
  .banner-sctn .maintitle { font-weight: 500; color: #000; font-size: clamp(22px, 3.4vw, 40px); line-height: 1.1; }
  .banner-sctn .banner-img { max-width: 100%; height: auto; margin: 26px auto; display: block; }
  .banner-sctn .warn { color: var(--red); margin: 0 0 6px; font-weight: 700; }
  .banner-sctn .warn-sub { color: var(--primary); font-size: clamp(18px, 2.4vw, 24px); line-height: 1.1; margin: 0 0 24px; }
  .banner-sctn .warn-btn { display: inline-block; background: var(--primary); color: #fff; padding: 11px 30px; border-radius: 4px; font-weight: 700; text-decoration: none; }
  .banner-sctn .warn-btn:hover { background: var(--red); }
  @media (max-width: 500px) { section.section.banner-sctn { padding-top: 45px; padding-bottom: 45px; } }

  /* ---------- 2. valuation-sctn (heading + contact form) ---------- */
  .valuation-sctn { background: var(--secondary); padding-top: 50px; padding-bottom: 50px; border-bottom: 5px solid var(--red); }
  .valuation-sctn .maintitle { color: #fff; text-align: center; margin-bottom: 24px; }
  .valuation-sctn .wpcf7 { width: 100%; max-width: 920px; }

  /* ---------- 3. why-sctn (reason cards) ---------- */
  .why-sctn { padding-top: 80px; padding-bottom: 70px; background: #fff; }
  .why-sctn .why-title { width: 100%; text-align: center; margin-bottom: 40px; }
  .why-sctn .why-title h2 { color: var(--primary); }
  .why-sctn .why-title span { color: var(--red); }
  .why-grid { display: flex; flex-wrap: wrap; gap: 30px; justify-content: center; width: 100%; }
  .why-card { width: calc(33.333% - 30px); display: flex; flex-direction: column; align-items: center; text-align: center; }
  .why-card .why-icon { min-height: 84px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
  .why-card .why-icon img { width: auto; height: auto; }
  .why-card h3 { color: var(--secondary); margin-bottom: 10px; }
  .why-card p { line-height: 1.5; font-size: 16px; color: #4d4d4d; }
  .why-card .why-cta { display: inline-block; margin-top: 14px; background: var(--primary); color: #fff; padding: 7px 18px; border-radius: 4px; font-size: 14px; font-weight: 600; text-decoration: none; }
  .why-card .why-cta:hover { background: var(--red); }
  .why-phone { width: 100%; text-align: center; margin-top: 44px; }
  .phone-cta { display: inline-flex; align-items: center; gap: 10px; background: var(--red); color: #fff; padding: 11px 26px; border-radius: 4px; font-weight: 700; font-size: 18px; text-decoration: none; }
  .phone-cta:hover { background: var(--primary); }
  .phone-cta svg { width: 18px; height: 18px; fill: currentColor; }
  @media (max-width: 900px) { .why-card { width: calc(50% - 30px); } }
  @media (max-width: 600px) { .why-card { width: 100%; } .why-sctn { padding-top: 45px; } }

  /* ---------- 4. video-aalt-sctn ---------- */
  .video-aalt-sctn { padding-top: 70px; padding-bottom: 70px; background: var(--secondary); background-image: linear-gradient(rgba(0,0,0,.55), rgba(0,0,0,.55)); }
  .video-aalt-sctn .title-col { width: 100%; text-align: center; margin-bottom: 26px; }
  .video-aalt-sctn .tc { color: #fff; }
  .video-aalt-sctn .title-col h2 span { color: #fff; opacity: .85; }
  .video-aalt-sctn .img-col { width: 100%; display: flex; justify-content: center; }
  .video-aalt-sctn .lyte-wrapper { width: 853px; max-width: 100%; filter: drop-shadow(2px 4px 6px rgba(0,0,0,.4)); }
  .video-aalt-sctn lite-youtube { width: 100%; max-width: 100%; border-radius: 4px; }
  @media (max-width: 500px) { .video-aalt-sctn { padding-top: 40px; padding-bottom: 40px; } }

  /* ---------- 5. cbi-info-section ---------- */
  .cbi-info-section { padding: clamp(60px,8vw,90px) 0; background: #d3d3d3; color: var(--black); }
  .cbi-info-section .cbi-head { width: 100%; text-align: center; margin-bottom: 36px; }
  .cbi-info-section .cbi-head h2 { display: inline-block; }
  .cbi-info-section .cbi-head h2 span { background: #fff; padding: 4px 22px; color: var(--primary); }
  .cbi-info-section .cbi-head h3 { color: var(--secondary); margin-top: 14px; }
  .cbi-cols { display: flex; flex-wrap: wrap; align-items: center; gap: 30px; width: 100%; }
  .cbi-text { width: calc(50% - 15px); }
  .cbi-text p { font-size: 15px; text-align: justify; line-height: 1.6; color: var(--secondary); }
  .cbi-btn { display: inline-block; margin-top: 16px; background: var(--red); color: #fff; padding: 8px 20px; border-radius: 4px; font-weight: 600; font-size: 14px; text-decoration: none; }
  .cbi-btn:hover { background: var(--primary); }
  .cbi-video { width: calc(50% - 15px); }
  .cbi-video .lyte-wrapper { width: 100%; filter: drop-shadow(2px 4px 6px rgba(0,0,0,.35)); }
  .cbi-video lite-youtube { width: 100%; border-radius: 4px; }
  @media (max-width: 900px) {
    .cbi-text, .cbi-video { width: 100%; }
    .cbi-info-section { padding-left: 20px; padding-right: 20px; }
  }

  /* ---------- Shared contact form (.bottom-form) — verbatim from city pages ---------- */
  .bottom-form { display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; background: var(--primary); padding: 36px 30px; color: #fff; border-radius: 6px; }
  .bottom-form input:not([type=submit]) { background: #fff; border: none; border-bottom: 2px solid var(--red); max-width: 100%; width: 100%; min-height: 31px; padding: 10px 13px; }
  .bottom-form .wpcf7-form-control-wrap { max-width: 100%; width: 100%; display: block; }
  .bottom-form textarea { width: 100%; padding: 10px; font-family: sans-serif; height: 98px; border: none; min-height: 98px; }
  .bottom-form .col-1 label, .bottom-form .col-2 label, .bottom-form .col-3 label, .bottom-form .col-4 label { display: none; }
  .bottom-form .col-1, .bottom-form .col-2, .bottom-form .col-3 { width: calc(33% - 8px); display: flex; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
  .bottom-form .col-4 { width: 100%; }
  .bottom-form .col-4 .wpcf7-form-control-wrap, .bottom-form .col-5 .wpcf7-form-control-wrap { width: 100%; }
  .bottom-form .col-5 { display: flex; justify-content: space-between; position: relative; text-align: left; width: 100%; gap: 4px; align-items: center; }
  .bottom-form .col-5 .wpcf7-list-item.first { margin-left: 0; }
  .bottom-form .col-5 .wpcf7-list-item-label { font-size: 12px; }
  .bottom-form .col-5 .bst-way > label { width: 100%; display: block; }
  .bottom-form .wpcf7-list-item { margin-left: 4px; }
  .bottom-form .wpcf7-list-item label { display: flex; align-items: center; }
  .bottom-form .wpcf7-radio { display: flex; gap: 8px; }
  .bottom-form .bst-way { color: #fff; text-transform: uppercase; font-weight: 600; display: flex; gap: 12px; align-items: center; font-size: 12px; }
  .bottom-form input::placeholder, .bottom-form textarea::placeholder { color: #555; }
  .bottom-form button[type=submit] { border: 0; color: var(--primary); padding: 6px 20px; border-radius: 100px; width: 100%; max-width: 180px; background: #fff; font-weight: 700; text-transform: uppercase; min-width: fit-content; cursor: pointer; }
  @media (max-width: 600px) {
    .bottom-form .col-5 { flex-direction: column; text-align: center; }
    .bottom-form .wpcf7-radio { justify-content: center; }
    .bottom-form button[type=submit] { width: 100%; }
    .bottom-form .col-1, .bottom-form .col-2, .bottom-form .col-3 { width: 100%; }
    .bottom-form .bst-way { gap: 4px; flex-direction: column; align-items: center; }
  }

  .pr-hp { position: absolute !important; left: -9999px !important; width: 1px; height: 1px; overflow: hidden; }
  .pr-form-banner { width: 100%; margin-top: 14px; font-weight: 600; }
  .pr-form-banner[data-state="success"] { color: #fff; }
  .pr-form-banner[data-state="error"] { color: #ffd9d9; }
</style>
