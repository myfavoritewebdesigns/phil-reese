---
/**
 * Single blog post — PRESERVED PERMALINK at /<category>/<slug>/.
 *
 * Phil Reese's WP served posts at /<category>/<slug>/ (e.g.
 * /buying-or-selling/the-right-time-to-sell-your-family-business/), NOT the
 * template default /blog/<slug>/. getStaticPaths returns one {category, slug}
 * pair per post, derived from frontmatter `category` (the URL-prefix slug set at
 * import time from the live permalink) + the file id (slug). This reproduces the
 * 32 indexed URLs exactly so no redirects are needed for posts.
 *
 * Renders the post body (MDX), injects full BlogPosting JSON-LD, and adds
 * newer/older post navigation. Author is Phil Reese (single-author site).
 */

import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getPublishedPosts, getAdjacentPosts, getRelatedPosts, formatDate, postUrl } from "../../lib/blog";
import type { BlogPost } from "../../lib/blog";
import { SITE_URL, SITE_NAME } from "../../config/site";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { category: post.data.category, slug: post.id },
    props: { post, allPosts: posts },
  }));
};

interface Props {
  post: BlogPost;
  allPosts: BlogPost[];
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const {
  title, description, pubDate, modifiedDate,
  author, category, categoryName, categories, tags, featuredImage,
  seoTitle, seoDescription, canonical, noindex,
  ogImage, ogImageAlt,
} = post.data;

const relPostUrl = postUrl(post);          // /<category>/<slug>/
const fullPostUrl = `${SITE_URL}${relPostUrl}`;
const categoryUrl = `/${category}/`;
const categoryLabel = categoryName ?? category.replace(/-/g, " ");

const { newer, older } = getAdjacentPosts(allPosts, post);
const related = getRelatedPosts(allPosts, post, 4);

// BlogPosting JSON-LD — Google's E-E-A-T signal source. Includes author,
// publisher (the global Organization @id), dates, image, and section.
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${fullPostUrl}#article`,
  headline: title,
  description,
  mainEntityOfPage: { "@type": "WebPage", "@id": fullPostUrl },
  url: fullPostUrl,
  datePublished: pubDate.toISOString(),
  dateModified: (modifiedDate ?? pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: author.name,
    ...(author.url ? { url: author.url } : {}),
    ...(author.avatar ? { image: author.avatar.startsWith("http") ? author.avatar : `${SITE_URL}${author.avatar}` } : {}),
  },
  publisher: { "@id": `${SITE_URL}/` },
  image: featuredImage?.src
    ? (featuredImage.src.startsWith("http") ? featuredImage.src : `${SITE_URL}${featuredImage.src}`)
    : `${SITE_URL}/images/og-default.jpg`,
  articleSection: categories.length ? categories : [categoryLabel],
  ...(tags.length ? { keywords: tags.join(", ") } : {}),
};
---

<Layout
  title={seoTitle ?? `${title} | ${SITE_NAME}`}
  description={seoDescription ?? description}
  canonical={canonical ?? relPostUrl}
  ogImage={ogImage ?? featuredImage?.src}
  ogImageAlt={ogImageAlt ?? featuredImage?.alt ?? title}
  ogType="article"
  noIndex={noindex}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(modifiedDate ?? pubDate).toISOString()}
  structuredData={articleSchema}
>
  <article class="pr-post">
    <header class="pr-post__header">
      <p class="pr-post__categories">
        <a href={categoryUrl}>{categoryLabel}</a>
      </p>

      <h1 class="pr-post__title">{title}</h1>

      <p class="pr-post__meta">
        By <span class="pr-post__author">{author.name}</span>
        {" · "}
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {modifiedDate && modifiedDate.getTime() !== pubDate.getTime() && (
          <>
            {" · "}
            <span>Updated <time datetime={modifiedDate.toISOString()}>{formatDate(modifiedDate)}</time></span>
          </>
        )}
      </p>
    </header>

    {featuredImage && (
      <figure class="pr-post__hero">
        <img
          src={featuredImage.src}
          alt={featuredImage.alt}
          width={featuredImage.width ?? 1200}
          height={featuredImage.height ?? 675}
          fetchpriority="high"
        />
        {featuredImage.caption && (
          <figcaption>{featuredImage.caption}{featuredImage.credit && ` — ${featuredImage.credit}`}</figcaption>
        )}
      </figure>
    )}

    <div class="pr-post__body">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="pr-post__related" aria-label="Related posts">
        <h3 class="pr-post__related-heading">Related posts:</h3>
        <ul class="pr-post__related-list">
          {related.map((r) => (
            <li><a href={postUrl(r)}>{r.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <nav class="pr-post__adjacent" aria-label="More posts">
      {newer ? (
        <a href={postUrl(newer)} class="pr-post__adjacent-link pr-post__adjacent-link--newer">
          <span class="pr-post__adjacent-label">← Newer post</span>
          <span class="pr-post__adjacent-title">{newer.data.title}</span>
        </a>
      ) : <div />}
      {older && (
        <a href={postUrl(older)} class="pr-post__adjacent-link pr-post__adjacent-link--older">
          <span class="pr-post__adjacent-label">Older post →</span>
          <span class="pr-post__adjacent-title">{older.data.title}</span>
        </a>
      )}
    </nav>

    <p class="pr-post__backlink">
      <a href="/blog/">← Back to all articles</a>
    </p>
  </article>
</Layout>

<style>
  .pr-post {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .pr-post__categories {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8125rem;
    color: var(--color-muted-text, #6b6b6b);
    margin: 0 0 0.5rem;
  }
  .pr-post__categories a {
    color: inherit;
    text-decoration: none;
  }
  .pr-post__categories a:hover { text-decoration: underline; }
  .pr-post__title {
    font-size: 2.5rem;
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  @media (min-width: 768px) {
    .pr-post__title { font-size: 3rem; }
  }
  .pr-post__meta {
    color: var(--color-muted-text, #6b6b6b);
    font-size: 0.9375rem;
    margin: 0 0 2rem;
  }
  .pr-post__meta a { color: inherit; }
  .pr-post__hero {
    margin: 0 0 2rem;
  }
  .pr-post__hero img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  .pr-post__hero figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-muted-text, #6b6b6b);
    font-style: italic;
    text-align: center;
  }
  .pr-post__body {
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .pr-post__body :global(h2) { font-size: 1.875rem; margin: 2.5rem 0 1rem; }
  .pr-post__body :global(h3) { font-size: 1.375rem; margin: 2rem 0 0.75rem; }
  .pr-post__body :global(p)  { margin: 0 0 1.25rem; }
  /* Images migrated from WP carry alignleft/alignright/aligncenter classes and
     inline width styles. Keep them in-flow and never wider than the column so
     displayed size ≈ natural size (no flex-stretch). */
  .pr-post__body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1.5rem 0;
  }
  .pr-post__body :global(.aligncenter) {
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  .pr-post__body :global(.alignleft),
  .pr-post__body :global(.alignleftnew) {
    float: left;
    margin: 0.5rem 1.5rem 1rem 0;
    max-width: 50%;
  }
  .pr-post__body :global(.alignright) {
    float: right;
    margin: 0.5rem 0 1rem 1.5rem;
    max-width: 50%;
  }
  /* WP "caption" wrapper divs carry an inline width — let the image fill it. */
  .pr-post__body :global(.caption) { max-width: 100%; height: auto; }
  @media (max-width: 600px) {
    .pr-post__body :global(.alignleft),
    .pr-post__body :global(.alignleftnew),
    .pr-post__body :global(.alignright) {
      float: none;
      max-width: 100%;
      margin: 1.5rem 0;
    }
  }
  .pr-post__body :global(blockquote) {
    border-left: 4px solid var(--color-brand-primary, #682412);
    padding: 0.5rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-muted-text, #6b6b6b);
    font-style: italic;
  }
  .pr-post__body :global(ul),
  .pr-post__body :global(ol) { margin: 0 0 1.25rem 1.25rem; }
  .pr-post__body :global(li) { margin: 0 0 0.5rem; }
  .pr-post__body :global(a) { color: var(--color-brand-primary, #682412); }
  /* Migrated YouTube embeds (WP Lyte → clean responsive iframe). */
  .pr-post__body :global(.pr-video) {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 1.5rem 0;
    clear: both;
  }
  .pr-post__body :global(.pr-video iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 8px;
  }

  .pr-post__related {
    margin: 3rem 0 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #e5e5e5);
    clear: both;
  }
  .pr-post__related-heading {
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }
  .pr-post__related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .pr-post__related-list a {
    color: var(--color-brand-primary, #682412);
    text-decoration: none;
    font-weight: 600;
  }
  .pr-post__related-list a:hover { text-decoration: underline; }

  .pr-post__adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 2.5rem 0 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #e5e5e5);
    clear: both;
  }
  @media (max-width: 640px) {
    .pr-post__adjacent { grid-template-columns: 1fr; }
  }
  .pr-post__adjacent-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .pr-post__adjacent-link:hover { background: var(--color-muted, #f4f4f4); }
  .pr-post__adjacent-link--older { text-align: right; }
  .pr-post__adjacent-label {
    font-size: 0.8125rem;
    color: var(--color-muted-text, #6b6b6b);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .pr-post__adjacent-title {
    font-weight: 600;
  }
  .pr-post__backlink {
    margin: 1.5rem 0 0;
  }
  .pr-post__backlink a {
    color: var(--color-brand-primary, #682412);
    text-decoration: none;
    font-weight: 600;
  }
  .pr-post__backlink a:hover { text-decoration: underline; }
</style>
