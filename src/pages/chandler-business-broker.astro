</Layout>

<!-- Section CSS — lifted verbatim from the live used-CSS
     (reference/_css-chandler-business-broker.css). is:global because the
     lite-youtube children carry no Astro scope hash. -->
<style is:global>
  /* ---------- Chandler page-scoped CSS vars (live :root subset) ---------- */
  .hlpr-sect { --gap-sm: 15px; --gap-md: 30px; --gap-lg: 50px; --color-text: #333333; --color-border: #e2e8f0; --color-bg-light: #f9f9f9; }

  /* ---------- type / utility helpers ---------- */
  .tc, .text-center { text-align: center; }
  .mt-3 { margin-top: 3%; }
