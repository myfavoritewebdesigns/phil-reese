  /* ---------- 3. test-sctn-alt (reviews) ---------- */
  .test-sctn { background: linear-gradient(360deg, #e8e8e8 0, #e7e7e7 30%, #e7e7E700 100%) no-repeat padding-box; padding-top: 80px; padding-bottom: 80px; }
  section.section.test-sctn { overflow: hidden; }
  .test-sctn .title-col { flex-grow: 1; max-width: 750px; padding-right: 20px; margin-left: auto; }
  .test-sctn .title-col .subtitle { margin: 0; color: var(--secondary); font-size: clamp(28px, 3vw, 42px); }
  .test-sctn .google-col { display: flex; align-items: center; gap: 20px; background: #fff; box-shadow: 0 0 15px 0 rgba(0, 0, 0, .25); padding: 20px; margin-right: -40px; width: 44%; border-radius: 7px; }
