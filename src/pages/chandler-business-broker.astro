  .card-lctn { border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; background: #fff; display: flex; flex-direction: column; }
  .card-lctn .col-img img { width: 100%; height: auto; object-fit: cover; max-width: 100%; display: block; }
  .card-lctn .col-text { padding: 20px; }
  .card-lctn h4 { margin-top: 0; font-size: 18px; color: var(--primary); }
</style>
