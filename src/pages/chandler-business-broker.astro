  .mb-10 { margin-bottom: 10px; }
  .mb-20 { margin-bottom: 20px; }

  /* ---------- 1. title-bar ---------- */
  .section.title-bar { padding-top: 52px; padding-bottom: 52px; background-color: #f9f9f9; box-shadow: 0 0 15px 0 rgba(0, 0, 0, .25); z-index: 2; }
