        {districts.map((d) => (
          <div class="pt-district">
            <h3 class="pt-district-name">{d.name}</h3>
            <p>{d.body}</p>
          </div>
        ))}
      </div>
      <img class="pt-banner-img" decoding="async" loading="lazy" src="/images/peoria-business-broker-test/districts.jpg" alt="A revitalizing main-street commercial district in the Arizona West Valley" width="1100" height="412" />
    </div>
  </section>

  <!-- 7. INDUSTRIES (bespoke) -->
  <section class="section pt-industries">
    <div class="section-wrap">
      <h2 class="pt-h2">Businesses We Help Buy And Sell In Peoria</h2>
      <p class="pt-lede">These are the businesses that change hands across the West Valley. Each one sells differently, and Phil knows how.</p>
      <div class="pt-ind-grid">
        {industries.map((it) => (
          <div class="pt-ind">
            <h3 class="pt-ind-title">{it.title}</h3>
            <p>{it.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. infogrhp-sctn — Selling process (VERBATIM from homepage) -->
