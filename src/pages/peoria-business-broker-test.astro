    <div class="section-wrap">
      <div class="title-col">
        <h3 class="maintitle h3-style">Some of the Businesses I have sold</h3>
      </div>
      {soldCols.map((col) => (
        <div class="sold-col">
          <h4 class="subtitle h4-style">{col.headline} <span>{col.type}</span></h4>
          <ul>
            {col.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- 5. MARKET SNAPSHOT (bespoke) -->
  <section class="section pt-stats">
    <div class="section-wrap">
      <h2 class="pt-h2">The Peoria Market At A Glance</h2>
      <p class="pt-lede">Peoria's rapid growth and rising incomes make it a magnet for motivated buyers coming out of Glendale, Surprise, and Sun City. That demand is exactly what you want behind you when it is time to sell.</p>
      <div class="pt-stat-grid">
        {stats.map((s) => (
          <div class="pt-stat">
            <div class="pt-stat-big">{s.big}</div>
            <div class="pt-stat-label">{s.label}</div>
            <div class="pt-stat-sub">{s.sub}</div>
          </div>
        ))}
      </div>
      <p class="pt-sources">Sources: U.S. Census Bureau, City of Peoria Economic Development, Arizona Commerce Authority.</p>
    </div>
  </section>

  <!-- 6. DISTRICTS (bespoke) -->
