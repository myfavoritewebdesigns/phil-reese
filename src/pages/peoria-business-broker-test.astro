/* ---------- Page schema ---------- */
const breadcrumbSchema = { "@type": "BreadcrumbList", "@id": `${SITE_URL}/peoria-business-broker-test/#breadcrumb`, itemListElement: [{ "@type": "ListItem", position: 1, name: "AZ Business Broker", item: `${SITE_URL}/` }, { "@type": "ListItem", position: 2, name: "Peoria Business Broker" }] };
const personSchema = { "@type": "Person", "@id": `${SITE_URL}/#phil-reese`, name: "Phil Reese", jobTitle: "Certified Business Intermediary (CBI, MCBI)", worksFor: { "@type": "Organization", name: "West USA Realty" }, areaServed: "Peoria, Arizona", url: `${SITE_URL}/`, image: `${SITE_URL}/images/home/phil-reese-portrait.png`, sameAs: [...socialSameAs] };
const serviceSchema = { "@type": "Service", "@id": `${SITE_URL}/peoria-business-broker-test/#service`, name: "Business Brokerage in Peoria, AZ", serviceType: "Business Broker", description: "Confidential business sales, acquisitions, and valuations for owners and buyers in Peoria and across the West Valley.", areaServed: { "@type": "City", name: "Peoria, Arizona" }, provider: { "@type": "ProfessionalService", name: "Phil Reese, Arizona Business Broker", "@id": `${SITE_URL}/`, url: `${SITE_URL}/` } };
const howToSchema = { "@type": "HowTo", "@id": `${SITE_URL}/peoria-business-broker-test/#howto`, name: "How To Sell A Business In Peoria, AZ", description: "The step-by-step process Phil Reese uses to sell a Peoria business confidentially and for the best price.", step: processSteps.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.name, text: s.body })) };
const faqPageSchema = { "@type": "FAQPage", "@id": `${SITE_URL}/peoria-business-broker-test/#faq`, mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
const structuredData = [{ "@context": "https://schema.org", "@graph": [breadcrumbSchema, personSchema, serviceSchema, howToSchema, faqPageSchema] }, financialServiceSchema];

/* Real "Phoenix Business Broker" GBP embed (Phil's nearest office to Peoria). */
const mapEmbed = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d252976.70164133824!2d-112.16530657552893!3d33.5815996356273!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x872b6fd570785e0f%3A0xf98213e260568250!2sPhoenix%20Business%20Broker!5e0!3m2!1sen!2spe!4v1774302238563!5m2!1sen!2spe";
