---
/* -----------------------------------------------------------------------
   Tempe Business Broker — faithful ("close enough") clone of
   https://www.philsellsbiz.com/tempe-business-broker/
   CITY local-SEO page. Content body verbatim from the live page
   (reference/_tempe-business-broker-content.html — de-lazified, images
   localized, CF7 form swapped for /api/contact, wp-youtube-lyte swapped for
   lite-youtube). Section CSS from the live used-CSS + the shared city-page
   section vocabulary.
   Sections in DOM order (10 live sections):
     1. banner-sctn      — H1 + H2 subhead
     2. philo-sctn       — intro copy + Tempe.jpg
     3. vid-sctn         — contact form + Phil contact info column
     4. test-sctn        — Google rating + 2 short testimonials + CBI role copy
     5. video-aalt-sctn  — Tempe video + sell/buy copy
     6. areas-sctn       — 4 city service-area links
     7. cbi-info-section — 3 badge-cards (Local / Valuation / Buyer Rep)
     8. faq-sctn         — 6 FAQ <details>
     9. map-sctn         — Scottsdale office map (near Tempe)
    10. lctn-sctn        — 5 Tempe neighborhood cards
   JSON-LD = live Yoast @graph (WebPage/ImageObject/BreadcrumbList) +
   standalone FinancialService + the live FAQPage schema, verbatim.
   ----------------------------------------------------------------------- */
import Layout from "../layouts/Layout.astro";
import { SITE_URL } from "../config/site";
import bodyHtml from "../../reference/_tempe-business-broker-content.html?raw";
import jsonldGraph from "../../reference/tempe-business-broker-jsonld-graph.json";
import financialServiceSchema from "../../reference/tempe-business-broker-jsonld-financialservice.json";
import faqSchema from "../../reference/tempe-business-broker-jsonld-extra.json";

/* Live <title> + meta description, verbatim from reference/tempe-business-broker-raw.html */
const pageTitle = "Tempe Business Broker Phil Reese";
const pageDescription =
  "If you would like to sell your Tempe business, call our expert Tempe business broker. The Tempe business sales market is up and now is the time to sell.";

const ogImage = `${SITE_URL}/images/tempe-business-broker/og-tempe-business-broker.jpg`;

/* Live page emits: Yoast @graph (WebPage/ImageObject/BreadcrumbList) +
   standalone FinancialService + a FAQPage schema. Replicated verbatim
   (Layout already injects the global LocalBusiness + WebSite nodes). */
const structuredData = [jsonldGraph, financialServiceSchema, faqSchema];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/tempe-business-broker/"
  ogImage={ogImage}
  ogImageAlt="Tempe Business Broker Phil Reese"
  ogImageWidth={1200}
  ogImageHeight={1200}
  structuredData={structuredData}
>
  <!-- lite-youtube web component — replaces the live wp-youtube-lyte lazy embed. -->
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.css"
  />
  <script
    slot="head"
    is:inline
    src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.js"
    defer></script>

  <!-- City page body — verbatim live content (images localized, form -> /api/contact). -->
  <Fragment set:html={bodyHtml} />
</Layout>

<!-- Lazy-load the Google Map embed the same way live (WP Rocket) does:
     iframe starts at about:blank, swaps in data-lazy-src when scrolled near. -->
<script is:inline>
  (function () {
    var frames = document.querySelectorAll("iframe[data-lazy-src]");
    if (!frames.length) return;
    function load(frame) {
      if (frame.dataset.loaded) return;
      frame.dataset.loaded = "1";
      frame.src = frame.dataset.lazySrc;
    }
    if (!("IntersectionObserver" in window)) { frames.forEach(load); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { load(entry.target); io.unobserve(entry.target); }
      });
    }, { rootMargin: "400px 0px" });
    frames.forEach(function (f) { io.observe(f); });
  })();
</script>

<!-- Section CSS — lifted from the live used-CSS + shared city-page vocabulary.
     is:global because the content arrives via set:html. -->
<style is:global>
  /* Local fallback for the live theme's undefined --gray (used by .faq-sctn). */
  .faq-sctn { --gray: #cecece; }

  /* ---------- WP alignment helpers (live theme-style.css) ---------- */
  .alignnone { max-width: 100%; height: auto; }
  .aligncenter { display: block; margin-left: auto; margin-right: auto; max-width: 100%; height: auto; }
  .alignleft { float: left; margin-right: 40px; box-shadow: 1px 1px 3px #333; }
  .aligncenternew { text-align: center; margin-top: 30px; margin-bottom: 30px; box-shadow: 1px 1px 3px #333; border: 1px solid #ccc; min-width: 100px; max-width: 100%; height: auto; }

  /* ---------- 1. banner-sctn ---------- */
  .banner-sctn { padding-top: 80px; padding-bottom: 80px; background: #f9f9f9; box-shadow: 0 0 15px 0 rgba(0,0,0,.25); z-index: 1; }
  .banner-sctn .maintitle { font-weight: 500; color: var(--primary); font-size: clamp(24px, 4vw, 54px); }
  .banner-sctn .one-col { text-align: center; }
  .banner-sctn .subtitle { color: var(--primary); font-weight: 400; font-size: 30px; margin-bottom: 0; }
  @media (max-width: 500px) {
    .banner-sctn { padding-bottom: 40px; padding-left: 20px; padding-right: 20px; }
    .banner-sctn .subtitle { font-size: 26px; }
  }
  @media (max-width: 400px) { section.section.banner-sctn { padding-top: 45px; } }

  /* ---------- 2. philo-sctn ---------- */
  .philo-sctn { padding-top: 80px; padding-bottom: 80px; }
  .philo-sctn .txt-col { width: 55%; margin-bottom: 40px; padding-right: 5%; }
  .philo-sctn .img-col { display: flex; width: 45%; }
  .philo-sctn .img-col img { width: 100%; height: auto; }
  .philo-sctn .section-wrap { align-items: center; }
  .philo-sctn .txt-col .maintitle { color: var(--primary); font-size: clamp(29px, 4vw, 48px); }
  .philo-sctn .txt-col p { line-height: 1.5; font-size: 18px; color: var(--secondary); }
  @media (max-width: 1024px) {
    .philo-sctn .img-col { max-width: 360px; width: 100%; }
    .philo-sctn .txt-col { width: 100%; text-align: center; padding: 0 15px; }
  }
  @media (max-width: 500px) {
    .philo-sctn .txt-col { padding: 0; }
    .philo-sctn { padding-top: 40px; padding-bottom: 40px; }
  }

  /* ---------- 3. vid-sctn (contact form + contact info) ---------- */
  .vid-sctn { background: #d3d3d3; padding-top: 50px; padding-bottom: 50px; border-bottom: 5px solid var(--red); }
  .vid-sctn .section-wrap { align-items: center; justify-content: space-between; }
  .vid-sctn .vid-col { width: 60%; }
  .vid-sctn .titlecol { padding: 40px 30px; width: 38%; color: var(--secondary); font-size: 17px; line-height: 1.7; }
  .vid-sctn .titlecol > div:first-child { font-weight: 700; color: var(--primary); }
  .vid-sctn .titlecol a { color: var(--red); font-weight: 600; }
  .vid-sctn .titlecol p { font-size: 13px; color: #4e4e4e; margin-top: 16px; }
  @media (max-width: 800px) {
    .vid-sctn .vid-col { width: 100%; order: 1; margin-top: 30px; }
    .vid-sctn .titlecol { width: 100%; padding: 0; text-align: center; }
    section.section.vid-sctn { padding-top: 40px; }
  }

  /* ---------- 4. test-sctn ---------- */
  .test-sctn { background: linear-gradient(360deg,#e8e8e8 0,#e7e7e7 30%,#e7e7E700 100%) no-repeat padding-box; padding-top: 80px; padding-bottom: 80px; }
  section.section.test-sctn { overflow: hidden; }
  .test-sctn .maintitle { margin: 0; font-family: sans-serif; font-weight: 400; color: var(--red); }
  .test-sctn .subtitle { margin: 0; color: var(--secondary); font-size: clamp(28px, 3vw, 42px); }
  .test-sctn .section-wrap { align-items: center; max-width: none; gap: 20px; }
  .test-sctn .h4-style { margin-bottom: 0; width: 100%; text-align: center; }
  .test-sctn .subtitle, .test-sctn .h3-style { width: 100%; text-align: center; }
  .test-sctn .google-col { display: flex; align-items: center; gap: 20px; background: #fff; box-shadow: 0 0 15px 0 rgba(0,0,0,.25); padding: 20px; border-radius: 7px; margin: 0 auto; max-width: 400px; }
  .test-sctn .google-col p { margin: 0; text-transform: uppercase; color: var(--primary); font-weight: 600; font-size: 16px; }
  .test-sctn .google-col .strs { font-size: 20px; }
  .test-sctn .name { color: var(--red); font-weight: 700; margin-bottom: 4px; }
  .test-sctn img { max-width: 100%; height: auto; }
  .test-sctn p { font-size: 17px; line-height: 1.5; }
  @media (max-width: 800px) { section.section.test-sctn { padding-top: 50px; padding-bottom: 50px; } }

  /* ---------- 5. video-aalt-sctn (with lite-youtube) ---------- */
  .video-aalt-sctn { padding-top: 80px; padding-bottom: 80px; }
  .video-aalt-sctn .txt-col { width: 50%; padding-left: 5%; }
  .video-aalt-sctn .img-col { width: 50%; }
  .video-aalt-sctn .title-col { width: 100%; text-align: center; margin-top: 32px; }
  .video-aalt-sctn .section-wrap { align-items: center; }
  .video-aalt-sctn .tc { text-align: center; color: var(--primary); }
  .video-aalt-sctn p { line-height: 1.5; font-size: 18px; color: var(--secondary); }
  .video-aalt-sctn .lyte-wrapper { filter: drop-shadow(2px 4px 6px rgba(0,0,0,.4)); }
  .video-aalt-sctn lite-youtube { width: 100%; max-width: 100%; border-radius: 4px; }
  @media (max-width: 1024px) {
    .video-aalt-sctn .img-col { width: 100%; }
    .video-aalt-sctn .txt-col { width: 100%; text-align: center; padding: 0 15px; }
  }
  @media (max-width: 500px) {
    .video-aalt-sctn .txt-col { padding: 0; }
    .video-aalt-sctn { padding-top: 40px; padding-bottom: 40px; }
  }

  /* ---------- 6. areas-sctn ---------- */
  .areas-sctn { color: var(--primary); padding: 80px 20px; box-shadow: 0 0 15px 0 rgba(0,0,0,.25); }
  .areas-sctn .maintitle { font-size: clamp(28px, 4vw, 40px); font-family: var(--font-family--h3); display: flex; width: 100%; align-items: center; gap: 20px; font-weight: 400; text-align: center; }
  .areas-sctn .maintitle:before,
  .areas-sctn .maintitle:after { content: ''; flex-grow: 1; background: var(--primary); height: 2px; }
  .links-inn { display: flex; flex-wrap: wrap; width: 100%; gap: 20px 5%; justify-content: center; list-style: none; padding: 0; margin: 0; }
  .links-inn a { color: var(--primary); text-decoration: underline; font-size: 18px; font-weight: 700; }
  @media (max-width: 800px) { .areas-sctn { padding-top: 32px; padding-bottom: 32px; } }

  /* ---------- 7. cbi-info-section ---------- */
  .cbi-info-section { padding: clamp(60px,8vw,100px) 0; color: var(--black); background: #d3d3d3; text-align: center; }
  .cbi-info-section .section-wrap { flex-direction: column; align-items: center; gap: 40px; }
  .cbi-info-section > .section-wrap > h3 { color: var(--primary); text-align: center; }
  .cbi-badge-container { display: flex; gap: 30px; justify-content: center; flex-wrap: wrap; }
  .badge-card { background: var(--white); border: 1px solid var(--light-gray); border-radius: 12px; padding: 30px; max-width: 450px; box-shadow: 0 10px 30px rgba(0,0,0,.05); transition: transform .3s ease, box-shadow .3s ease; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .badge-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(16,33,77,.1); border-color: var(--primary); }
  .badge-card img { width: 64px; height: 64px; }
  .badge-card h4 { font-size: var(--font-size--h4); color: var(--secondary); margin-bottom: 15px; max-width: 308px; }
  .badge-card .p-style { line-height: 1.5; font-size: 18px; color: var(--secondary); }
  @media (min-width: 801px) { .badge-card { width: calc(33% - 30px); } }
  @media (max-width: 1024px) { .cbi-info-section { padding-left: 20px; padding-right: 20px; } }
  @media (max-width: 800px) { .badge-card { width: 100%; } }
  @media (max-width: 768px) { .badge-card { max-width: 100%; } }
  @media (max-width: 500px) { .badge-card { padding: 21px; } }

  /* ---------- 8. faq-sctn ---------- */
  .faq-sctn { padding-top: 80px; padding-bottom: 32px; }
  .faq-sctn .h3-style { text-align: center; }
  .faq-sctn .faq-title { margin: 0; font-size: 21px; font-weight: 700; color: var(--primary); }
  .faq-sctn details { border-bottom: 2px solid var(--gray); margin-bottom: 10px; padding-bottom: 6px; width: 100%; }
  .faq-sctn summary { border-bottom: 2px solid var(--red); padding-bottom: 13px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; gap: 4px; cursor: pointer; }
  .faq-sctn summary::-webkit-details-marker { display: none; }
  .faq-sctn p { line-height: 1.55; }

  /* ---------- 9. map-sctn ---------- */
  .map-sctn { padding-top: 60px; padding-bottom: calc(3% + 32px); }
  .map-sctn .section-wrap { justify-content: center; }
  .map-sctn .title-col { background-color: var(--primary); text-align: center; color: var(--white); width: 100%; max-width: 900px; }
  .map-sctn .title-col .aligncenternew { margin-top: 0; margin-bottom: 0; box-shadow: none; border: 0; width: 100%; }
  .map-sctn .title-col .h3-style { margin-top: 32px; margin-bottom: 8px; }
  .map-sctn .title-col h3 { padding-right: 20px; padding-left: 20px; }
  .map-sctn iframe { width: 900px; max-width: 100%; height: auto; aspect-ratio: 2/1; border: 0; }

  /* ---------- 10. lctn-sctn ---------- */
  .lctn-sctn { padding-top: calc(32px + 3%); padding-bottom: calc(32px + 3%); }
  .lctn-sctn .h3-style, .lctn-sctn .h4-style { width: 100%; text-align: center; }
  .lctn-sctn .h3-style { margin-bottom: 8px; }
  .lctn-sctn .lctn-col-cont { display: flex; gap: 32px; flex-wrap: wrap; justify-content: space-evenly; }
  .lctn-sctn .card-lctn { width: calc(20% - 32px); background: #eeeded; padding: 20px; border-radius: 12px; border: 1px solid var(--primary); margin: 0; flex-grow: 1; text-align: center; }
  .lctn-sctn .card-lctn img { max-width: 100%; height: auto; border-radius: 6px; }
  .lctn-sctn .card-lctn .h6-style { color: var(--red); font-family: var(--font-family--h6); font-size: var(--font-size--h6); font-weight: 700; }
  .lctn-sctn .card-lctn p:last-child { margin: 0; }
  @media (max-width: 1024px) and (min-width: 801px) { .lctn-sctn .card-lctn { width: calc(33% - 32px); } }
  @media (max-width: 800px) and (min-width: 501px) { .lctn-sctn .card-lctn { width: calc(50% - 32px); } }
  @media (max-width: 500px) { .lctn-sctn .card-lctn { width: 100%; } }

  /* ---------- shared contact-form (.bottom-form) — city --primary bg variant ---------- */
  .bottom-form { display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; background: var(--primary); padding: 36px 30px; color: #fff; border-radius: 6px; }
  .bottom-form input:not([type=submit]) { background: #fff; border: none; border-bottom: 2px solid var(--red); max-width: 100%; width: 100%; min-height: 31px; padding: 10px 13px; }
  .bottom-form .wpcf7-form-control-wrap { max-width: 100%; width: 100%; display: block; }
  .bottom-form textarea { width: 100%; padding: 10px; font-family: sans-serif; height: 98px; border: none; min-height: 98px; }
  .bottom-form .col-1 label, .bottom-form .col-2 label, .bottom-form .col-3 label, .bottom-form .col-4 label { display: none; }
  .bottom-form .col-1, .bottom-form .col-2, .bottom-form .col-3 { width: calc(33% - 8px); display: flex; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
  .bottom-form .col-4 { width: 100%; }
  .bottom-form .col-4 .wpcf7-form-control-wrap, .bottom-form .col-5 .wpcf7-form-control-wrap { width: 100%; }
  .bottom-form .col-5 { display: flex; justify-content: space-between; position: relative; text-align: left; width: 100%; gap: 4px; align-items: center; }
  .bottom-form .col-5 .wpcf7-list-item.first { margin-left: 0; }
  .bottom-form .col-5 .wpcf7-list-item-label { font-size: 12px; }
  .bottom-form .col-5 .bst-way > label { width: 100%; display: block; }
  .bottom-form .wpcf7-list-item { margin-left: 4px; }
  .bottom-form .wpcf7-list-item label { display: flex; align-items: center; }
  .bottom-form .wpcf7-radio { display: flex; gap: 8px; }
  .bottom-form .bst-way { color: #fff; text-transform: uppercase; font-weight: 600; display: flex; gap: 12px; align-items: center; font-size: 12px; }
  .bottom-form input::placeholder, .bottom-form textarea::placeholder { color: #555; }
  .bottom-form button[type=submit] { border: 0; color: var(--primary); padding: 6px 20px; border-radius: 100px; width: 100%; max-width: 180px; background: #fff; font-weight: 700; text-transform: uppercase; min-width: fit-content; cursor: pointer; }
  @media (max-width: 600px) {
    .bottom-form .col-5 { flex-direction: column; text-align: center; }
    .bottom-form .wpcf7-radio { justify-content: center; }
    .bottom-form button[type=submit] { width: 100%; }
    .bottom-form .col-1, .bottom-form .col-2, .bottom-form .col-3 { width: 100%; }
    .bottom-form .bst-way { gap: 4px; flex-direction: column; align-items: center; }
  }

  /* Honeypot + form status banner */
  .pr-hp { position: absolute !important; left: -9999px !important; width: 1px; height: 1px; overflow: hidden; }
  .pr-form-banner { width: 100%; margin-top: 14px; font-weight: 600; }
  .pr-form-banner[data-state="success"] { color: #fff; }
  .pr-form-banner[data-state="error"] { color: #ffd9d9; }
</style>
