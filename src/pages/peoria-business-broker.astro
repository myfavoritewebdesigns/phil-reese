  "Experienced Peoria business broker Phil Reese provides expert valuations for clients buying or selling a business or commercial property.";

const ogImage = `${SITE_URL}/images/peoria-business-broker/og-peoria.jpg`;

/* Page JSON-LD — Layout injects the global Organization + WebSite graph;
