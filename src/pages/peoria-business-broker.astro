const structuredData = [webGraph, financialServiceSchema, faqPageSchema, reviewsGraph];

/* ---------- test-sctn-alt review boxes (verbatim) ---------- */
const reviews = [
  { name: "Mike Williams", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURXdFpxSzJnRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDWtZqK2gE%7CCgwI0PaSkgYQoI3VtgE%7C?hl=en-US", text: "If you have ever bought or sold a company, you know that it's an incredibly complex endeavor, sometimes with many unexpected twists and turns along the way. The smart person soon learns this is not something you should take on without the help of an expert to guide you. Phil Reese may well be the best and brightest expert you can find.  Phil was amazing to work with throughout the entire process of selling our company. He was always highly professional and available to answer every kind of question or concern. We really don't know how we could have gotten through the tedious, roller-coaster process without him. And best of all, his guidance assured us the best possible results with an excellent buyer and top-level offer at the end of the day. We highly recommend Phil Reese!" },
  { name: "Mark Wdowiak", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURRbDRucmdRRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDQl4nrgQE%7CCgwI04_q0gUQwJ6YuwI%7C?hl=en-US", text: "To anyone looking to buy or sell a business, do yourself a HUGE favor and use the services of Phil Reese! We had used other business brokers in the past and had less than desired results. In 2015 Phil listed and sold our multi-million dollar business in 6 months. His knowledge, support, enthusiasm, professionalism and his personalized service is outstanding! Listing our business with Phil was absolutely the best decision we could have made! We love him and so will you! Mark and Juanita Wdowiak" },
  { name: "Steve Sweeney", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VMTzl3NlROXzV2NUh3EAE!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKELO9w6TN_5v5Hw%7CCgwI09GRwgYQyPmU_wE%7C?hl=en-US", text: "I wish I could give 10 stars.  Phil was an absolute professional to work with.  He would answer any questions we had in a timely manner, let us know the status on a regular basis and always kept our best interest at top of his list.  The top two traits I can think of to describe him are Professionalism and Integrity. You will not go wrong with choosing Phil." },
  { name: "Joanne Manning", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VJQ0FnSUR5OFktUVZnEAE!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDy8Y-QVg%7CCgwIs8yoggYQsPS01AM%7C?hl=en-US", text: "Phil came highly recommended to us after selling a friend of ours business. So we gave him a call and Phil did a great job selling our business. He was there every step of the way going out of his way to help in all areas. I would and will recommend him to anyone wanting to sell their business." },
  { name: "Tim Ransom", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VJQ0FnSURzbUwtbVdBEAE!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDsmL-mWA%7CCgsI077G8gUQkKyxKw%7C?hl=en-US", text: "We were very pleased with Phil Reese, he is a real pro.  We highly recommend his services." },
  { name: "karen benedek", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURqdy1EanZ3RRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDjw-DjvwE%7CCgwI9r3lsQYQiMry2wI%7C?hl=en-US", text: "I had a question regarding my business, and Phil was very kind, taking his time to converse with me, even though I didn't use his service. He was awesome, and I will definitely keep his information and refer him to clients. A very professional gentleman." },
];

/* ---------- cbi-info-section badge cards (verbatim) ---------- */
const whyCards = [
  { img: "icon-expertise.png", alt: "Phil Reese Simplifying Business Ownership Transitions for Peoria Company Owners", title: "Expertise In Buying & Selling Businesses", body: "With a deep understanding of business ownership transitions and a commitment to efficient solutions, Phil Reese connects industry knowledge with practical strategies to simplify buying and selling processes. From precise valuations and targeted marketing to skilled negotiations, Phil offers tailored support for every client’s unique goals. His expertise spans a variety of industries, making him a versatile and trusted partner. Choose Phil to navigate the challenges and opportunities of your business transition with confidence and professionalism." },
  { img: "icon-valuations.png", alt: "Expert Business Valuations in Peoria by Phil Reese", title: "Comprehensive Business Valuations", body: "Let Phil Reese deliver a precise and thorough valuation for your business. By analyzing financial performance, market conditions, and industry trends, Phil provides a reliable assessment of your business’s worth. This clarity equips business owners to set realistic goals, attract serious buyers, and negotiate with confidence. Whether you’re planning to sell, exploring opportunities, or strategizing for the future, Phil’s valuation expertise ensures you have the insights needed to make informed decisions and maximize your results." },
  { img: "icon-buyer-rep.png", alt: "Phil Reese Provides Expert Guidance for Buying a Business in Peoria", title: "Expert Buyer Representation Service", body: "Phil Reese offers buyers expert guidance through every stage of purchasing a business. From identifying opportunities to handling negotiations, we ensure clients make informed, confident decisions. Our thorough market knowledge and commitment to your success simplify the buying process and help you find the perfect fit. With Phil by your side, purchasing a business becomes a streamlined and rewarding experience." },
];

/* ---------- faq-sctn (verbatim Q/A; A uses <Fragment set:html> for inline <br>) ---------- */
const faqs = [
  { q: "Q: What Industries Do Your Business Brokers Specialize In?", a: `We work across a wide range of industries. These include retail, manufacturing, healthcare, professional services, hospitality, technology, and more. Our expertise lies in understanding market trends and tailoring strategies to suit the specifics of each sector. Whether you’re in a niche market or a high-demand industry, our skilled brokers uses their knowledge to connect you with the right buyers and ensure a smooth transaction.<br>` },
  { q: "Q: How Long Does It Take To Sell A Business Through A Broker?", a: `The time frame for selling a business varies depending on factors such as industry, market conditions, and business valuation. On average, it can take 6 to 12 months to complete a sale. A broker like Phil Reese works to streamline the process by preparing your business, marketing it effectively, and managing negotiations, all while ensuring you achieve the best possible outcome without unnecessary delays.<br>` },
  { q: "Q: How Is The Value Of My Business Determined?", a: `Determining the value of your business is a detailed process that takes several factors into account. As an expert business broker, I start by thoroughly reviewing your financial performance, including revenue, profitability, and any historical trends. I also assess the current market conditions, industry trends, and recent sales of similar businesses in your area. This helps to establish a clear understanding of what buyers are willing to pay.<br><br>
        Beyond financials, I also consider the intangible elements that contribute to your business’s value, such as your customer base, brand reputation, and operational strengths. By combining all of these factors, I can provide a comprehensive and accurate valuation of your business. This not only helps in setting a fair asking price but also ensures that you maximize your return on investment when it’s time to sell. Ready to get an accurate valuation for your business? Contact me today to schedule a consultation and take the first step toward a successful sale.<br>` },
  { q: "Q: What Information Does A Broker Need To Sell My Business?", a: `To sell your business, a broker requires detailed information, including financial statements, tax returns, business operations data, asset inventories, and legal documentation. They also need insights into customer demographics, employee roles, and growth opportunities. This comprehensive information helps create a compelling business profile, attract serious buyers, and address questions during the negotiation process, ensuring a successful and transparent transaction.<br>` },
  { q: "Q: Can Business Brokers Help With Mergers & Acquisitions?", a: `Yes, brokers like Phil Reese have the expertise to manage mergers and acquisitions. They guide clients through valuation, buyer or seller identification, and negotiation while ensuring confidentiality. Their experience with complex deals allows them to navigate the nuances of combining businesses or acquiring new ones. With a broker’s help, clients achieve seamless transitions, whether expanding operations, consolidating resources, or entering new markets.<br>` },
  { q: "Q: What Are The Tax Implications Of Selling A Business?", a: `Selling a business involves tax considerations like capital gains taxes, depreciation recapture, and potential state or local taxes. A business broker collaborates with tax professionals to ensure you understand these implications and plan accordingly. Strategies like structuring the sale properly or taking advantage of tax deferrals can help minimize your tax burden. Phil Reese ensures you navigate these complexities effectively while maximizing the financial benefits of your sale.<br>` },
];

const mapEmbed = "https://maps.google.com/maps?q=Peoria,+AZ&z=11&output=embed";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/peoria-business-broker/"
  ogImage={ogImage}
  ogImageAlt="Peoria Business Broker"
  ogImageWidth={1200}
  ogImageHeight={1200}
  structuredData={structuredData}
  videoId="75l7CluKwIg"
>
  <!-- lite-youtube web component — replaces the live wp-youtube-lyte embed. -->
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.css"
  />
  <script
    slot="head"
    is:inline
    src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.js"
    defer></script>

  <!-- 1. banner-sctn -->
  <section class="section banner-sctn">
    <div class="section-wrap">
      <div class="one-col">
        <h1 class="maintitle h1-style" style="text-transform: uppercase;margin-bottom:0">Top-Rated Business Broker In Peoria, AZ</h1>
        <h2 class="subtitle h3-style">Peoria’s Leading Business Broker – Your Trusted Partner in Business Sales</h2>
      </div>
    </div>
  </section>

  <!-- 2. philo-sctn -->
  <section class="section philo-sctn">
    <div class="section-wrap">
      <div class="txt-col">
        <p>If you’re considering selling your business in Peoria, Phil Reese is the trusted partner you need to guide you through the process with confidence and ease. With over 20 years of experience as a Certified Business Intermediary and a reputation for integrity, Phil has helped countless entrepreneurs achieve successful business sales. Selling a business is one of the most significant decisions you’ll make, and Phil’s tailored strategies ensure your business is positioned to achieve its maximum value in the marketplace.</p>
        <p>Whether you’re transitioning to your next venture or preparing for retirement, Phil understands both the financial and emotional aspects of selling a business. He provides the clarity and support you need to make informed decisions with confidence.</p>
        <p>Trust Phil Reese to be your partner in achieving your goals. We guarantee a commitment to professionalism and empathy that will ensure only the best results.</p>
      </div>
      <div class="img-col">
        <img fetchpriority="high" decoding="async" src="/images/peoria-business-broker/Peoria.jpg" alt="Phil Reese, Your Local Business Broker for Peoria Companies" width="350" height="210" class="alignleft size-full" />
      </div>
    </div>
  </section>

  <!-- 3. vid-sctn — contact form + details -->
  <section class="section vid-sctn">
    <div class="section-wrap">
      <div class="vid-col">
        <div class="wpcf7">
          <form
            class="wpcf7-form"
            action="/api/contact"
            method="post"
            aria-label="Contact form"
            data-pr-contact-form
            data-form-id="peoria"
          >
            <input type="text" name="_honeypot" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="pr-hp" />
            <div class="bottom-form">
              <div class="col-1">
                <label for="first-name-bt">Name</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="text" name="your-name-bt" id="first-name-bt" class="wpcf7-form-control wpcf7-text" maxlength="400" placeholder="Name*" required aria-required="true" />
                </span>
              </div>
              <div class="col-2">
                <label for="your-email-bt">Email</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="email" name="your-email-bt" id="your-email-bt" class="wpcf7-form-control wpcf7-email wpcf7-text" maxlength="400" placeholder="Email*" required aria-required="true" />
                </span>
              </div>
              <div class="col-3">
                <label for="your-phone-bt">Phone</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="tel" name="your-phone-bt" id="your-phone-bt" class="wpcf7-form-control wpcf7-tel wpcf7-text" maxlength="400" placeholder="Phone" />
                </span>
              </div>
              <div class="col-4">
                <label for="your-message-bt">Your Message*</label>
                <span class="wpcf7-form-control-wrap">
                  <textarea name="your-message-bt" id="your-message-bt" class="wpcf7-form-control wpcf7-textarea" cols="40" rows="10" maxlength="2000" minlength="20" placeholder="Your Message*" required aria-required="true"></textarea>
                </span>
              </div>
              <div class="col-5">
                <div class="bst-way">
                  <label>Best Way to Reply:</label>
                  <span class="wpcf7-form-control-wrap">
                    <span class="wpcf7-form-control wpcf7-radio">
                      {replyMethods.map((method, i) => (
                        <span class={`wpcf7-list-item${i === 0 ? " first" : ""}${i === replyMethods.length - 1 ? " last" : ""}`}>
                          <label>
                            <input type="radio" name="bst-way-bt" value={method} checked={i === 0} />
                            <span class="wpcf7-list-item-label">{method}</span>
                          </label>
                        </span>
                      ))}
                    </span>
                  </span>
                </div>
                <button type="submit" class="wpcf7-form-control wpcf7-submit">Send</button>
              </div>
            </div>
          </form>
        </div>
      </div>
      <div class="titlecol">
        <h3 class="tc h3-style">Get In Touch Today</h3>
        <div>Phil Reese, CBI &#8211; Arizona Business Broker</div>
        <em>West USA Realty</em><br />
        Cell : <a href="tel:+14807077721">480-707-7721</a><br />
        Fax : <a href="tel:+14806074435">480-607-4435</a><br />
        Email: <a href="mailto:phil@philsellsbiz.com">phil@philsellsbiz.com</a><br />
        Website: <a href="/">https://philsellsbiz.com</a><br />
        <p>Serving: Peoria, Arizona</p>
      </div>
    </div>
  </section>

  <!-- 4. test-sctn — testimonials header -->
  <section class="section test-sctn">
    <div class="section-wrap">
      <div class="title-col">
        <h3 class="subtitle h3-style">Our Clients&#8217; Testimonials</h3>
        <h4 class="h4-style">5-Star Rated Business Broker In Peoria</h4>
      </div>
      <div class="google-col">
        <svg id="XMLID_1_" xmlns="http://www.w3.org/2000/svg" width="156.629" height="51.349" viewBox="0 0 156.629 51.349"><path d="M38.522,18.218H20.235v5.419H33.188c-.635,7.62-6.985,10.837-12.954,10.837A14.263,14.263,0,0,1,5.927,20.038,14.259,14.259,0,0,1,20.235,5.518a14.1,14.1,0,0,1,9.779,3.937l3.81-3.937A19.3,19.3,0,0,0,20.065.1,20.194,20.194,0,0,0,0,19.911,20.2,20.2,0,0,0,20.362,39.892c10.668,0,18.457-7.323,18.457-18.118a17.8,17.8,0,0,0-.3-3.556Z" transform="translate(0 -0.1)" fill="#4285f4"/><path d="M108.769,33.6A12.806,12.806,0,1,0,121.6,46.427c.042-8.466-6.646-12.827-12.827-12.827Zm.085,5.038c3.683,0,7.2,2.963,7.2,7.789a7.381,7.381,0,0,1-7.2,7.747c-4.064,0-7.323-3.26-7.323-7.789,0-4.445,3.175-7.747,7.323-7.747Z" transform="translate(-55.303 -19.419)" fill="#ea4335"/><path d="M174.969,33.6A12.806,12.806,0,1,0,187.8,46.427c0-8.466-6.689-12.827-12.827-12.827Zm.042,5.038c3.683,0,7.2,2.963,7.2,7.789a7.381,7.381,0,0,1-7.2,7.747c-4.064,0-7.323-3.26-7.323-7.789a7.4,7.4,0,0,1,7.323-7.747Z" transform="translate(-93.48 -19.419)" fill="#fbbc05"/><path d="M240.676,33.6c-6.9,0-12.276,6.011-12.276,12.784a12.639,12.639,0,0,0,12.192,12.827,8.516,8.516,0,0,0,7.027-3.09v2.54c0,4.4-2.667,7.069-6.731,7.069a7.133,7.133,0,0,1-6.561-4.572l-4.911,2.074c1.736,3.683,5.249,7.535,11.514,7.535,6.858,0,12.065-4.318,12.065-13.335V34.362h-5.376v2.159a9.41,9.41,0,0,0-6.943-2.921Zm.466,5.038c3.387,0,6.858,2.879,6.858,7.789,0,5-3.471,7.747-6.9,7.747-3.683,0-7.069-2.963-7.069-7.7-.042-4.911,3.514-7.831,7.112-7.831Z" transform="translate(-131.713 -19.419)" fill="#4285f4"/><path d="M326.438,33.5c-6.477,0-11.938,5.165-11.938,12.784a12.4,12.4,0,0,0,12.573,12.869,12.942,12.942,0,0,0,10.71-5.63l-4.445-2.963a7.13,7.13,0,0,1-6.265,3.514,6.57,6.57,0,0,1-6.265-3.895l17.187-7.069-.889-2.074A11.613,11.613,0,0,0,326.438,33.5Zm.254,4.953a5.082,5.082,0,0,1,4.741,2.752l-11.472,4.784c-.508-3.725,3.006-7.535,6.731-7.535Z" transform="translate(-181.365 -19.361)" fill="#ea4335"/><path d="M295.2,40.86h5.63V3.1H295.2Z" transform="translate(-170.235 -1.83)" fill="#34a853"/></svg>
      </div>
    </div>
