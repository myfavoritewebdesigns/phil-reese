/* ---------- "Why We're Gilbert's Preferred" badge cards (cbi-info-section), verbatim ---------- */
const badgeCards = [
  { img: "local-buy-sell.png", alt: "Local Buy And Sell Business Broker In Gilbert, AZ", title: "Local Sell & Buy Business Broker In Gilbert", body: "With a wealth of experience in facilitating successful business transactions, Phil Reese brings a nuanced understanding of Gilbert’s market dynamics. His Certified Business Intermediary designation underscores his commitment to professionalism and industry excellence. By choosing Phil, clients gain access to a broker who not only possesses experience but is also dedicated to ensuring a quality buying and selling processes." },
