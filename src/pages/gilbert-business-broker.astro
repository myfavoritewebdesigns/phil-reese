<!-- Lazy-load the Google Map iframe the same way live (WP Rocket) does. -->
<script is:inline>
  (function () {
    var frames = document.querySelectorAll("iframe[data-lazy-src]");
    if (!frames.length) return;
    function load(f) { if (f.dataset.loaded) return; f.dataset.loaded = "1"; f.src = f.dataset.lazySrc; }
    if (!("IntersectionObserver" in window)) { frames.forEach(load); return; }
    var io = new IntersectionObserver(function (es) {
      es.forEach(function (e) { if (e.isIntersecting) { load(e.target); io.unobserve(e.target); } });
    }, { rootMargin: "400px 0px" });
    frames.forEach(function (f) { io.observe(f); });
  })();
</script>

