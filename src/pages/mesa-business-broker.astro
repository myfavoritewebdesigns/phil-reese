---
/* -----------------------------------------------------------------------
   Mesa Business Broker — city local-SEO page (fidelity: "close enough").
   Faithful clone of https://www.philsellsbiz.com/mesa-business-broker/
   Markup/copy verbatim from reference/mesa-business-broker-raw.html.
   Section CSS lifted from the live WP-Rocket used-CSS
   (reference/_css-mesa-business-broker.css → _mesa-section-css.txt).
   Reuses shared section vocab established by index.astro / about / sellers
   (banner-sctn, vid-sctn form, test-sctn, areas-sctn, faq accordion, map).
   Sections in DOM order (11):
     1. banner-sctn       — H1 city headline + subhead
     2. philo-sctn        — intro copy + Mesa.jpg
     3. vid-sctn          — CF7 form (→/api/contact) + broker contact card
     4. test-sctn         — "Read Reviews" title + Google rating
     5. test-sctn-alt     — 6 Google reviews + CBI explainer (text-col)
     6. video-aalt-sctn   — lite-youtube (b8wO04kmk9M) + selling copy
     7. areas-sctn        — Arizona Service Areas city links
     8. cbi-info-section  — 3 "Why Choose" badge cards
     9. faq-sctn          — FAQ accordion (<details open>)
    10. map-sctn          — Mesa banner + Scottsdale office map iframe
    11. lctn-sctn         — 5 neighborhood cards
   ----------------------------------------------------------------------- */
import Layout from "../layouts/Layout.astro";
import { SITE_URL, contact, hrefs, replyMethods } from "../config/site";
import financialServiceSchema from "../../reference/home-financialservice-schema.json";
import faqPageSchema from "../../reference/city-mesa-faqpage.json";
import reviewsSchema from "../../reference/city-mesa-reviews.json";

/* Live <title> + meta description, verbatim from reference/mesa-business-broker-raw.html */
const pageTitle = "Expert Business Broker in Mesa Phil Reese";
const pageDescription =
  "If you are looking to sell your Mesa business or buy a Mesa business, contact expert Mesa business broker Phil Reese who is familiar with the Mesa market!";

/* Live og:image (localized; live primaryimage = .../2021/02/mesa-business-broker.jpg) */
const ogImage = `${SITE_URL}/wp-content/uploads/2021/02/mesa-business-broker.jpg`;

/* ---------- Page JSON-LD (Layout injects global LocalBusiness + WebSite) ----------
   Live emits a WebPage @graph + standalone FinancialService + FAQPage + Reviews. */
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${SITE_URL}/mesa-business-broker/`,
  url: `${SITE_URL}/mesa-business-broker/`,
  name: pageTitle,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  primaryImageOfPage: { "@id": `${SITE_URL}/mesa-business-broker/#primaryimage` },
  image: { "@id": `${SITE_URL}/mesa-business-broker/#primaryimage` },
  thumbnailUrl: ogImage,
  datePublished: "2015-05-20T22:07:05+00:00",
  dateModified: "2026-06-12T20:44:50+00:00",
  description: pageDescription,
  breadcrumb: { "@id": `${SITE_URL}/mesa-business-broker/#breadcrumb` },
  inLanguage: "en-US",
  potentialAction: [{ "@type": "ReadAction", target: [`${SITE_URL}/mesa-business-broker/`] }],
};
const primaryImageSchema = {
  "@type": "ImageObject",
  inLanguage: "en-US",
  "@id": `${SITE_URL}/mesa-business-broker/#primaryimage`,
  url: ogImage,
  contentUrl: ogImage,
  width: 1200,
  height: 1200,
};
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${SITE_URL}/mesa-business-broker/#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "AZ Business Broker", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Mesa Business Broker" },
  ],
};

const structuredData = [
  {
    "@context": "https://schema.org",
    "@graph": [webPageSchema, primaryImageSchema, breadcrumbSchema],
  },
  financialServiceSchema,
  faqPageSchema,
  reviewsSchema,
];

/* ---------- Areas served (areas-sctn), verbatim ---------- */
const areaLinks = [
  { href: "/phoenix-business-broker/", label: "Phoenix Business Broker" },
  { href: "/scottsdale-business-broker/", label: "Scottsdale Business Broker" },
  { href: "/tempe-business-broker/", label: "Tempe Business Broker" },
  { href: "/mesa-business-broker/", label: "Mesa Business Broker" },
];

/* ---------- 6 Google reviews (test-sctn-alt), verbatim ---------- */
const reviews = [
  { body: "I contacted Phil regarding a family member who was having issues with his business partner and was thinking about selling his half of the company. Phil did a valuation of the business and gave my family member very valuable advice.", name: "Russ K", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT25kNVpuVm5OV3BoUW5SUmRFcE9Uek5UTXpsTU9HYxAB!2m1!1s0x0:0x5050683fa73067b5!3m1!1s2@1:CAIQACodChtycF9oOnd5ZnVnNWphQnRRdEpOTzNTMzlMOGc%7C%7C?hl=en-US" },
  { body: "Phil has proven over the years that he can be relied on for confidentially. Many of his clients appreciate his consistent weekly updates, which keep them informed throughout the process. He's not the type of broker who lists a business and then disappears – he stays engaged and communicative from start to finish.", name: "Novella Wellington", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT21GcGRsWkRlVVZ0TWxWeWJYWlZNelZqYms1V1RuYxAB!2m1!1s0x0:0x5050683fa73067b5!3m1!1s2@1:CAIQACodChtycF9oOmFpdlZDeUVtMlVybXZVMzVjbk5WTnc%7C%7C?hl=en-US" },
  { body: "Phil is the best business broker in Arizona. He goes above and beyond for his clients.", name: "Shannon Kriloff", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT2tJMVVXZHdiVmQ2YTFCVmExSldZWGRsVWxaMmQxRRAB!2m1!1s0x0:0x5050683fa73067b5!3m1!1s2@1:CAIQACodChtycF9oOkI1UWdwbVd6a1BVa1JWYXdlUlZ2d1E%7C%7C?hl=en-US" },
  { body: "We have had a great experience selling our business with Phil Reese as our broker. He completed the sale of our business.  His 20+ years of experience were instrumental guiding our decision-making process to be successful. We highly recommend choosing Phil as your broker.", name: "Terri La France", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUNtbWJIRHV3RRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgICmmbHDuwE%7CCgwI4N_HjgYQ-Pu47gI%7C?hl=en-US" },
  { body: "We worked with Phil in selling our business and from day one we could tell he was a no nonsense and very detail oriented broker. He made sure we only dealt with pre-screened, qualified buyers and assisted with our questions at each step of the arduous and sometimes confusing process. I would recommend Phil to anyone looking to buy/sell a business.", name: "Joe Mangum", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VJQ0FnSURVdjgtbVhREAE!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDUv8-mXQ%7CCgwIupnb6wUQgML3yAI%7C?hl=en-US" },
  { body: "Phil was very professional in facilitating our transaction.  He knew what he was doing and is quite competent in following through with documenting the transaction and keeping all parties to the deal on track.  I'd recommend him to anyone seeking a competent business broker.", name: "Doug L", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUR3M082MDJnRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDw3O602gE%7CCgwI4cuJ3gUQ2KC98wI%7C?hl=en-US" },
];

/* ---------- "Why Choose" badge cards (cbi-info-section), verbatim ---------- */
const badgeCards = [
  { img: "local-buy-sell.png", alt: "Local Buy And Sell Business Broker In Mesa, AZ", title: "Local Mesa Business Buy & Sell Broker", body: "Phil Reese is a local business broker who can help you buy or sell your business in Mesa, Arizona. Phil is affiliated with West USA Realty, the largest business broker group in the state, giving your business the best possible exposure for buying and selling purposes." },
  { img: "valuation.png", alt: "Find out how much your business in Mesa is worth!", title: "Valuation of Your Mesa Business", body: "As a certified business intermediary, Phil Reese can provide you with a thorough valuation of your Mesa business for when you are looking to buy or sell. Phil is an honest, trusted, top rated business broker who can help negotiate the best price for your business." },
  { img: "buyer-representation.png", alt: "Buyer Representation By Phil Reese Broker in Mesa, AZ", title: "Buyer Representation", body: "When you are looking to obtain a business, Phil Reese can provide you with the best buyer representation in Mesa, Arizona. Phil is an experienced business broker in Arizona who can ensure that you receive the best buyer representation possible." },
];

/* ---------- FAQ accordion (faq-sctn), verbatim ---------- */
const faqs = [
  { q: "Q: Which Documents Are Required To Sell Your Business?", a: "You might need many documents when selling your business. These include financial statements, tax returns, contracts, leases, licenses, and other relevant records that provide a comprehensive overview of your business’s operations and financial performance. These documents are crucial in presenting a clear and accurate picture of your business to potential buyers, helping them make informed decisions during the due diligence process." },
  { q: "Q: How Long Does A Business Sale Usually Take?", a: "The duration of a business sale can vary significantly based on several factors. Complex businesses or those operating in niche markets might require more time to find the right buyer. Additionally, market conditions, negotiation dynamics, and the overall complexity of the transaction can influence the timeline. On average, a business sale can take anywhere from several months to a year or more. It’s important to remain patient and work closely with us to navigate the process effectively and achieve a successful outcome." },
  { q: "Q: How Is A Business Value Determined?", a: "Determining the value of a business involves a comprehensive evaluation process. We employ various methods to assess business value, including financial analysis, market research, and evaluation of tangible and intangible assets. We consider factors such as cash flow, profitability, growth potential, market demand, industry trends, and comparable business sales. By combining these factors and using our expertise, we can provide an accurate and fair valuation that reflects the market value of the business." },
  { q: "Q: What Are The Steps To Put A Company For Sale?", a: "Putting a company up for sale involves strategic steps to maximize the chances of a successful transaction. The process typically starts with preparing the business for sale, which includes organizing financial records, identifying strengths and weaknesses, and enhancing its appeal. The next steps involve determining an appropriate asking price, creating comprehensive marketing materials, identifying potential buyers, conducting negotiations, performing due diligence, and finalizing the legal and financial aspects. We can guide you through each of these steps, ensuring a smooth and efficient process." },
  { q: "Q: Do you only advertise businesses sales locally?", a: "As a Certified Business Intermediary, our marketing approach extends beyond local advertising. We employ a comprehensive strategy that encompasses local and national, advertising channels to reach a wide pool of potential buyers. Using different platforms, networks, databases, and targeted marketing techniques, we maximize exposure for your business and attract qualified buyers who may be interested in acquiring businesses within your industry or market niche." },
  { q: "Q: Which Taxes Will I Have To Pay In Order To Buy Or Sell A Business?", a: "The specific taxes involved in buying or selling a business can vary depending on several things, including the jurisdiction in which the transaction takes place and the structure of the deal. Common taxes that may apply include capital gains tax, sales tax, transfer taxes, and other applicable taxes specific to your location and circumstances. You can consult with a tax professional or accountant who specializes in business transactions to understand the tax implications." },
  { q: "Q: How Much Time Will I Have To Put Into The Business Selling Process?", a: "We’ll handle many aspects of the business selling process, but we recommend you be actively involved to ensure a successful outcome. The amount of time required can vary depending on factors such as the complexity of your business, the market conditions, and your level of involvement. You’ll be responsible for providing necessary information, participating in negotiations, and collaborating with us to address buyer inquiries and make informed decisions. By working closely with us, you can ensure that your interests are represented and that the process moves forward smoothly toward a successful sale." },
];

/* ---------- Neighborhood cards (lctn-sctn), verbatim ---------- */
const lctnCards = [
  { img: "lctn-01.jpg", alt: "Sell Your Company In Downtown Mesa", title: "Do You Want To Sell Your Company In Downtown Mesa? Call Phil Reese Today!", body: "Downtown Mesa is the city’s walkable urban core, home to local shops, restaurants, offices, and light rail. If you own a business here and are thinking about selling, Phil Reese can value it, find the right buyer, and keep the whole process confidential. Call today." },
  { img: "lctn-02.jpg", alt: "Business broker serving the Falcon District near Falcon Field, Mesa", title: "Buying Or Selling A Business In The Falcon District? Phil Reese Can Help", body: "The Falcon District around Falcon Field Airport is a hub for aerospace, advanced manufacturing, and technology companies. Whether you are buying or selling a service, industrial, or flex-space business out here, Phil Reese knows how to position it and reach qualified buyers." },
  { img: "lctn-03.jpg", alt: "Business broker serving the Elliot Road Technology Corridor in the Gateway area, Mesa", title: "Need Confidentiality Selling Your Business In The Gateway Area? Contact Phil", body: "The Gateway area and the Elliot Road Technology Corridor are growing fast around Mesa Gateway Airport. If you are ready to sell your business here without word getting out to your employees or customers, Phil Reese handles every step with discretion." },
  { img: "lctn-04.jpg", alt: "Business broker serving the Riverview District, Mesa", title: "Selling A Business Near The Riverview District? Call Phil Reese Today!", body: "The Riverview District along the 202 mixes retail, dining, offices, and entertainment near the Cubs spring-training ballpark. Selling a business in a busy commercial corridor like this takes the right approach, and Phil Reese is here to help. Give him a call." },
  { img: "lctn-05.jpg", alt: "Business broker serving the Fiesta District, Mesa", title: "Want To Buy A Business In The Fiesta District? Contact Phil Reese", body: "The Fiesta District is reinventing itself around healthcare, higher education, and innovation. If you want to own a business in this part of Mesa, reach out to Phil Reese. He works with buyers to find the right fit and walks you through the purchase." },
];

const IMG = "/images/mesa-business-broker";
const mapEmbed = "https://www.google.com/maps/embed?pb=!1m28!1m12!1m3!1d212930.58619477716!2d-112.03169729709425!3d33.500325765832365!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m13!3e6!4m5!1s0x872ba7c2c0c592c1%3A0xd10fc215694e771b!2sMesa%2C+AZ!3m2!1d33.4151843!2d-111.8314724!4m5!1s0x872b746aab1ed8d3%3A0xa8b2025d4488a51c!2s7077+E+Marilyn+Rd+%23130%2C+Scottsdale%2C+AZ+85254!3m2!1d33.619912!2d-111.928607!5e0!3m2!1sen!2sus!4v1432159617185";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/mesa-business-broker/"
  ogImage={ogImage}
  ogImageAlt="Expert Business Broker in Mesa Phil Reese"
  ogImageWidth={1200}
  ogImageHeight={1200}
  structuredData={structuredData}
  videoId="b8wO04kmk9M"
>
  <!-- lite-youtube web component — replaces the live wp-youtube-lyte embed. -->
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.css" />
  <script slot="head" is:inline src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.2/src/lite-yt-embed.js" defer></script>

  <!-- 1. banner-sctn -->
  <section class="section banner-sctn">
    <div class="section-wrap">
      <div class="one-col">
        <h1 class="maintitle h1-style" style="text-transform: uppercase;margin-bottom:0">Call Mesa Business Broker Phil Reese When You Are Ready To Sell Your Mesa Business!</h1>
        <h2 class="subtitle h3-style">Leading Business Broker Serving Company Owners In Mesa</h2>
      </div>
    </div>
  </section>

  <!-- 2. philo-sctn -->
  <section class="section philo-sctn">
    <div class="section-wrap">
      <div class="txt-col">
        <p>If you are looking to sell your Mesa business, you should consider the advantages of using a business broker who is familiar with the Mesa market.</p>
        <p>One advantage of using a <strong>Mesa business broker</strong> is their experience with real estate and business technicalities and legalities in the area. Inattention to any of these details can prove costly.</p>
      </div>
      <div class="img-col">
        <img fetchpriority="high" width="560" height="353" decoding="async" src={`${IMG}/Mesa.jpg`} alt="Phil Reese, Your Local Mesa AZ Business Broker" class="aligncenter size-full" />
      </div>
    </div>
  </section>

  <!-- 3. vid-sctn — CF7 form (→ /api/contact) + broker contact card -->
  <section class="section vid-sctn">
    <div class="section-wrap">
      <div class="vid-col">
        <div class="wpcf7">
          <form class="wpcf7-form" action="/api/contact" method="post" aria-label="Contact form" data-pr-contact-form data-form-id="mesa">
            <input type="text" name="_honeypot" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="pr-hp" />
            <div class="bottom-form">
              <div class="col-1">
                <label for="first-name-bt">Name</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="text" name="your-name-bt" id="first-name-bt" class="wpcf7-form-control wpcf7-text" maxlength="400" placeholder="Name*" required aria-required="true" />
                </span>
              </div>
              <div class="col-2">
                <label for="your-email-bt">Email</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="email" name="your-email-bt" id="your-email-bt" class="wpcf7-form-control wpcf7-email wpcf7-text" maxlength="400" placeholder="Email*" required aria-required="true" />
                </span>
              </div>
              <div class="col-3">
                <label for="your-phone-bt">Phone</label>
                <span class="wpcf7-form-control-wrap">
                  <input type="tel" name="your-phone-bt" id="your-phone-bt" class="wpcf7-form-control wpcf7-tel wpcf7-text" maxlength="400" placeholder="Phone" />
                </span>
              </div>
              <div class="col-4">
                <label for="your-message-bt">Your Message*</label>
                <span class="wpcf7-form-control-wrap">
                  <textarea name="your-message-bt" id="your-message-bt" class="wpcf7-form-control wpcf7-textarea" cols="40" rows="10" maxlength="2000" minlength="20" placeholder="Your Message*" required aria-required="true"></textarea>
                </span>
              </div>
              <div class="col-5">
                <div class="bst-way">
                  <label>Best Way to Reply:</label>
                  <span class="wpcf7-form-control-wrap">
                    <span class="wpcf7-form-control wpcf7-radio">
                      {replyMethods.map((method, i) => (
                        <span class={`wpcf7-list-item${i === 0 ? " first" : ""}${i === replyMethods.length - 1 ? " last" : ""}`}>
                          <label>
                            <input type="radio" name="bst-way-bt" value={method} checked={i === 0} />
                            <span class="wpcf7-list-item-label">{method}</span>
                          </label>
                        </span>
                      ))}
                    </span>
                  </span>
                </div>
                <button type="submit" class="wpcf7-form-control wpcf7-submit">Send</button>
              </div>
            </div>
          </form>
        </div>
      </div>
      <div class="titlecol">
        <p>Phil Reese, CBI – Arizona Business Broker</p>
        <em>West USA Realty</em>
        <br />
        Cell : <a href={hrefs.tel}>{contact.phoneDashed}</a>
        <br />
        Fax : <a href="tel:+14806074435">480-607-4435</a>
        <br />
        Email: <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <br />
        Website: <a href="/">https://philsellsbiz.com</a>
        <br />
        <div>Servicing: Mesa, Arizona</div>
        Your privacy is always important. Your information will not be shared, sold or exchanged with anyone else.
      </div>
    </div>
  </section>

  <!-- 4. test-sctn — reviews title + Google rating -->
  <section class="section test-sctn">
    <div class="section-wrap">
      <div class="title-col">
        <h3 class="subtitle h3-style">Read Reviews From Our Clients</h3>
        <h4 class="h4-style">Mesa Business Broker With 5-Star Rated Reviews</h4>
      </div>
      <div class="google-col">
        <svg id="XMLID_1_" xmlns="http://www.w3.org/2000/svg" width="156.629" height="51.349" viewBox="0 0 156.629 51.349">
          <path d="M38.522,18.218H20.235v5.419H33.188c-.635,7.62-6.985,10.837-12.954,10.837A14.263,14.263,0,0,1,5.927,20.038,14.259,14.259,0,0,1,20.235,5.518a14.1,14.1,0,0,1,9.779,3.937l3.81-3.937A19.3,19.3,0,0,0,20.065.1,20.194,20.194,0,0,0,0,19.911,20.2,20.2,0,0,0,20.362,39.892c10.668,0,18.457-7.323,18.457-18.118a17.8,17.8,0,0,0-.3-3.556Z" transform="translate(0 -0.1)" fill="#4285f4"/>
          <path d="M108.769,33.6A12.806,12.806,0,1,0,121.6,46.427c.042-8.466-6.646-12.827-12.827-12.827Zm.085,5.038c3.683,0,7.2,2.963,7.2,7.789a7.381,7.381,0,0,1-7.2,7.747c-4.064,0-7.323-3.26-7.323-7.789,0-4.445,3.175-7.747,7.323-7.747Z" transform="translate(-55.303 -19.419)" fill="#ea4335"/>
          <path d="M174.969,33.6A12.806,12.806,0,1,0,187.8,46.427c0-8.466-6.689-12.827-12.827-12.827Zm.042,5.038c3.683,0,7.2,2.963,7.2,7.789a7.381,7.381,0,0,1-7.2,7.747c-4.064,0-7.323-3.26-7.323-7.789a7.4,7.4,0,0,1,7.323-7.747Z" transform="translate(-93.48 -19.419)" fill="#fbbc05"/>
          <path d="M240.676,33.6c-6.9,0-12.276,6.011-12.276,12.784a12.639,12.639,0,0,0,12.192,12.827,8.516,8.516,0,0,0,7.027-3.09v2.54c0,4.4-2.667,7.069-6.731,7.069a7.133,7.133,0,0,1-6.561-4.572l-4.911,2.074c1.736,3.683,5.249,7.535,11.514,7.535,6.858,0,12.065-4.318,12.065-13.335V34.362h-5.376v2.159a9.41,9.41,0,0,0-6.943-2.921Zm.466,5.038c3.387,0,6.858,2.879,6.858,7.789,0,5-3.471,7.747-6.9,7.747-3.683,0-7.069-2.963-7.069-7.7-.042-4.911,3.514-7.831,7.112-7.831Z" transform="translate(-131.713 -19.419)" fill="#4285f4"/>
          <path d="M326.438,33.5c-6.477,0-11.938,5.165-11.938,12.784a12.4,12.4,0,0,0,12.573,12.869,12.942,12.942,0,0,0,10.71-5.63l-4.445-2.963a7.13,7.13,0,0,1-6.265,3.514,6.57,6.57,0,0,1-6.265-3.895l17.187-7.069-.889-2.074A11.613,11.613,0,0,0,326.438,33.5Zm.254,4.953a5.082,5.082,0,0,1,4.741,2.752l-11.472,4.784c-.508-3.725,3.006-7.535,6.731-7.535Z" transform="translate(-181.365 -19.361)" fill="#ea4335"/>
          <path d="M295.2,40.86h5.63V3.1H295.2Z" transform="translate(-170.235 -1.83)" fill="#34a853"/>
        </svg>
        <div>
          <p>Over 60 reviews</p>
          <span>5.0 <span class="strs">★★★★★</span></span>
        </div>
      </div>
    </div>
  </section>

