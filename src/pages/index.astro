  {
    headline: "$3,720,000",
    type: "Grocery Store",
    items: [
      "$850,000 HVAC Company",
      "$810,000 Electrical Contractor",
      "$800,000 Party & Event Rental Co.",
      "$750,000 Niche Wood Product Co.",
