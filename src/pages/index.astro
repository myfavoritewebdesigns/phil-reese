/* -----------------------------------------------------------------------
   Homepage — faithful clone of https://www.philsellsbiz.com/
   Spec: reference/_home-extract.md (10 sections, DOM order).
   Markup/copy verbatim from reference/home-raw.html; section CSS verbatim
   from the live WP-Rocket used-CSS (reference/_css-wpr-usedcss.css).
   Notes:
   - No photo hero on this page — the "hero" is the light #f9f9f9 banner-sctn.
   - Video uses the lite-youtube CDN pattern (replaces live wp-youtube-lyte).
   - Map iframes replicate live's lazy pattern (src=about:blank +
     data-lazy-src, swapped in by the IntersectionObserver script below).
   - CF7 form rebuilt with the live field names (your-name-bt, your-email-bt,
     your-phone-bt, your-message-bt, bst-way-bt) → /api/contact via the
     shared contact-form.ts handler.
   ----------------------------------------------------------------------- */
import Layout from "../layouts/Layout.astro";
import { SITE_URL, contact, offices, replyMethods, socialSameAs } from "../config/site";
import ibbaBadgeSvg from "../../reference/ibba-badge-html.html?raw";
import googleGLogoSvg from "../../reference/google-g-logo-svg.html?raw";
import whyIcon1Svg from "../../reference/why-icon-1-business-owner-svg.html?raw";
import whyIcon2Svg from "../../reference/why-icon-2-mcbi-svg.html?raw";
import whyIcon4Svg from "../../reference/why-icon-4-valuations-svg.html?raw";
import whyIcon5Svg from "../../reference/why-icon-5-bbb-svg.html?raw";
/* Live page's standalone FinancialService schema (3 office nodes), verbatim —
   extracted from reference/home-raw.html (second ld+json script). */
import financialServiceSchema from "../../reference/home-financialservice-schema.json";

/* Live <title> + meta description, verbatim from reference/home-raw.html */
const pageTitle =
  "Phil Reese, Arizona Business Broker | Offices In Scottsdale & Phoenix";
const pageDescription =
  "Sell your business with AZ Business Broker Phil Reese, a local AZ business broker with Offices In Phoenix & Scottsdale.";

const ogImage = `${SITE_URL}/images/home/og-home.jpg`;

/* ---------- Page JSON-LD (Layout already injects LocalBusiness + WebSite) ---------- */
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${SITE_URL}/#webpage`,
  url: `${SITE_URL}/`,
  name: pageTitle,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  primaryImageOfPage: { "@id": `${SITE_URL}/#primaryimage` },
  image: { "@id": `${SITE_URL}/#primaryimage` },
  thumbnailUrl: ogImage,
  datePublished: "2026-03-02T12:43:27+00:00",
  dateModified: "2026-06-02T21:36:36+00:00",
  description: pageDescription,
  breadcrumb: { "@id": `${SITE_URL}/#breadcrumb` },
  inLanguage: "en-US",
  potentialAction: [{ "@type": "ReadAction", target: [`${SITE_URL}/`] }],
};

const primaryImageSchema = {
  "@type": "ImageObject",
  inLanguage: "en-US",
  "@id": `${SITE_URL}/#primaryimage`,
  url: ogImage,
  contentUrl: ogImage,
  width: 1200,
  height: 1200,
  caption: `Phil Reese, Arizona Business Broker, Offices In Scottsdale & Phoenix ${SITE_URL}/`,
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${SITE_URL}/#breadcrumb`,
  itemListElement: [{ "@type": "ListItem", position: 1, name: "AZ Business Broker" }],
};

/* Person schema — Phil + every office as a workLocation Place */
function officePlace(o: (typeof offices)[number]) {
  const [locality, regionZip = ""] = o.cityLine.split(/,\s*/);
  const [region = "AZ", postalCode = ""] = regionZip.trim().split(/\s+/);
  return {
    "@type": "Place",
    name: o.title,
    telephone: o.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: o.street.replace(/,$/, ""),
      addressLocality: locality,
      addressRegion: region,
      postalCode,
      addressCountry: "US",
    },
  };
}

const personSchema = {
  "@type": "Person",
  "@id": `${SITE_URL}/#person`,
  name: "Phil Reese",
  jobTitle: "Arizona Business Broker",
  honorificSuffix: "MCBI",
  description:
    "Master Certified Business Intermediary (MCBI) and former Ethics Chairman of the Arizona Business Brokers Association (AZBBA), helping Arizona business owners sell their companies since 2001.",
  url: `${SITE_URL}/`,
  image: `${SITE_URL}/images/home/phil-reese-portrait.png`,
  telephone: contact.telDashed,
  email: contact.email,
  worksFor: { "@id": `${SITE_URL}/` },
  sameAs: [...socialSameAs],
  workLocation: offices.map(officePlace),
};

/* Yoast-style @graph wrapper (mirrors how live emits its page schema), plus
   the live page's standalone FinancialService office schema, verbatim. */
const structuredData = [
  {
    "@context": "https://schema.org",
    "@graph": [webPageSchema, primaryImageSchema, breadcrumbSchema, personSchema],
  },
  financialServiceSchema,
];

/* ---------- Sold businesses (sold-sctn), verbatim ---------- */
