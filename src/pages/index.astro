/* ---------- Mobile steps (infogrhp-sctn ≤500px), verbatim ---------- */
const sptDividerSvg = `<svg id="spt-dt" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 171.76 41.56"><polygon class="st0" points="2 41.56 0 41.56 0 28.96 169.76 9.06 169.76 0 171.76 0 171.76 10.84 2 30.74 2 41.56"/></svg>`;

