---
/**
 * Paginated blog archive.
 *
 *   /blog/         → page 1
 *   /blog/page/2/  → page 2
 *   /blog/page/N/  → page N
 *
 * `paginate()` returns { props: { page }, params: { page: "2" | undefined } }.
 * The catch-all [...page].astro lets us serve both /blog/ and /blog/page/N/
 * from a single file. Page 1 is at the bare /blog/ — required to match WP's
 * standard URL shape (WP serves /blog/ for page 1, /blog/page/2/ for page 2).
 */

import type { GetStaticPaths, GetStaticPathsOptions, Page } from "astro";
import Layout from "../../layouts/Layout.astro";
import BlogPostCard from "../../components/primitives/BlogPostCard.astro";
import Pagination from "../../components/primitives/Pagination.astro";
import { getPublishedPosts, getAllCategories, getAllTags, paginationUrl } from "../../lib/blog";
import type { BlogPost } from "../../lib/blog";
import { SITE_URL, SITE_NAME } from "../../config/site";

// getStaticPaths runs in an isolated scope — any constants it needs MUST be
// defined inside its body (module-level consts aren't visible).
export const getStaticPaths: GetStaticPaths = async ({ paginate }: GetStaticPathsOptions) => {
  const POSTS_PER_PAGE = 10;
  const posts = await getPublishedPosts();
  // Stub a single page when there are no posts so /blog/ still renders.
  if (posts.length === 0) {
    return [{
      params: { page: undefined },
      props:  { page: { data: [], start: 0, end: 0, size: POSTS_PER_PAGE, total: 0, currentPage: 1, lastPage: 1, url: { current: "/blog/", prev: undefined, next: undefined, first: undefined, last: undefined } } },
    }];
  }
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
};

interface Props {
  page: Page<BlogPost>;
}

const { page } = Astro.props;
const [categories, tags] = await Promise.all([getAllCategories(), getAllTags()]);

// Page-1 canonical lives at /blog/, never at /blog/page/1/ (which we don't generate anyway).
const canonical = paginationUrl("/blog", page.currentPage);

const isPaged = page.currentPage > 1;
const title = isPaged
  ? `Blog — Page ${page.currentPage} | ${SITE_NAME}`
  : `Blog | ${SITE_NAME}`;
const description = isPaged
  ? `Page ${page.currentPage} of blog posts from ${SITE_NAME}.`
  : `Latest articles from ${SITE_NAME}.`;

const prevPageUrl = page.url.prev ? `${SITE_URL}${page.url.prev}` : undefined;
const nextPageUrl = page.url.next ? `${SITE_URL}${page.url.next}` : undefined;
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogType="website"
>
  <Fragment slot="head">
    {prevPageUrl && <link rel="prev" href={prevPageUrl} />}
    {nextPageUrl && <link rel="next" href={nextPageUrl} />}
  </Fragment>

  <div class="pr-blog-archive">
    <header class="pr-blog-archive__header">
      <h1>{isPaged ? `Blog — Page ${page.currentPage}` : "Blog"}</h1>
      {!isPaged && <p>Latest articles, guides, and news.</p>}
    </header>

    <div class="pr-blog-archive__grid">
      <section class="pr-blog-archive__list">
        {page.data.length === 0 ? (
          <p>No posts published yet. Check back soon.</p>
        ) : (
          <ul class="pr-blog-archive__items">
            {page.data.map((post) => (
              <li><BlogPostCard post={post} /></li>
            ))}
          </ul>
        )}

        <Pagination
          currentPage={page.currentPage}
          totalPages={page.lastPage}
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
          basePath="/blog"
        />
      </section>

      <aside class="pr-blog-archive__sidebar">
        {categories.length > 0 && (
          <div class="pr-blog-archive__widget">
            <h2>Categories</h2>
            <ul>
              {categories.map((c) => (
                <li>
                  <a href={`/category/${c.slug}/`}>{c.name}</a>
                  <span class="pr-blog-archive__count">({c.count})</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {tags.length > 0 && (
          <div class="pr-blog-archive__widget">
            <h2>Tags</h2>
            <ul class="pr-blog-archive__tags">
              {tags.map((t) => (
                <li>
                  <a href={`/tag/${t.slug}/`}>{t.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
</Layout>

<style>
  .pr-blog-archive {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .pr-blog-archive__header {
    margin-bottom: 2.5rem;
  }
  .pr-blog-archive__header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem;
  }
  .pr-blog-archive__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 960px) {
    .pr-blog-archive__grid {
      grid-template-columns: minmax(0, 1fr) 280px;
    }
  }
  .pr-blog-archive__items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2rem;
  }
  .pr-blog-archive__sidebar h2 {
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.75rem;
    color: var(--color-muted-text, #6b6b6b);
  }
  .pr-blog-archive__widget {
    margin-bottom: 2rem;
  }
  .pr-blog-archive__widget ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pr-blog-archive__widget li {
    padding: 0.25rem 0;
  }
  .pr-blog-archive__count {
    color: var(--color-muted-text, #6b6b6b);
    font-size: 0.875rem;
    margin-left: 0.25rem;
  }
  .pr-blog-archive__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pr-blog-archive__tags li {
    padding: 0;
  }
  .pr-blog-archive__tags a {
    display: inline-block;
    background: var(--color-muted, #f4f4f4);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.875rem;
    text-decoration: none;
  }
  .pr-blog-archive__tags a:hover {
    background: var(--color-brand-primary, #682412);
    color: #fff;
  }
</style>
