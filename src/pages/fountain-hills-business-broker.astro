/* ---------- 3 service cards (cbi-badge-container), verbatim ---------- */
const serviceCards = [
  { img: "local-buy-sell-mesa-business-broker.png", alt: "Local Buy And Sell Business Broker", h4: "Local Sell & Buy Business Broker In Fountain Hills", p: "Choose Phil Reese as your Fountain Hills business broker for seamless local buying and selling transactions. With his extensive understanding of the Fountain Hills business scene and a proven history of successful deals, Phil stands as your reliable ally in navigating the intricacies of the local market. Reach out to us today for further details on how Phil can assist you." },
  { img: "valuation-mesa-business.png", alt: "Fountain Hills Company Valuation", h4: "Valuation Of Your Fountain Hills Business", p: "Phil Reese is your go-to expert for meticulous and precise business valuations tailored to local companies. Drawing on his in-depth knowledge of the Fountain Hills market, industry dynamics, and financial analytics, Phil delivers comprehensive assessments of your business’s value. Whether you’re contemplating a sale, exploring financing options, or strategizing for the future, Phil’s valuation services offer invaluable insights to guide your decision-making process." },
  { img: "buyer-representation-mesa-arizona.png", alt: "Buyer Representation By Phil Reese Broker In Fountain Hills, AZ", h4: "Buyer Representation", p: "Phil Reese brings a profound understanding of the Fountain Hills market to the table, assisting you in pinpointing ideal acquisition opportunities. From thorough due diligence to negotiating advantageous terms, Phil guides you through every step of the buying process with expertise and dedication. Trust Phil to be your ideal partner in achieving your business acquisition goals in Tempe." },
