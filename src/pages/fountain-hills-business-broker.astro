/* -----------------------------------------------------------------------
   Fountain Hills Business Broker — faithful clone of
   https://www.philsellsbiz.com/fountain-hills-business-broker/
   City local-SEO page. Markup/copy verbatim from
   reference/fountain-hills-business-broker-raw.html; section CSS verbatim from
   the live WP-Rocket used-CSS (reference/_fh-inline.css) +
   reference/_peoria-business-broker-sections.css.
   Live DOM (the outer test-sctn wraps several nested sections, replicated):
     1. banner-sctn       — H1 + subtitle + 3 paragraphs + BBB rating row
     2. vid-sctn          — "CONTACT ME" contact form
     3. test-sctn (wrapper)
        ├─ title-col + google-col (reviews header)
        ├─ test-sctn-alt — 6 reviews
        ├─ philo-sctn    — "What Does A CBI Do" + contract image
        ├─ cbi-info-section — cbi-header (text + video) + 3 service cards
        ├─ areas-sctn    — 4 city links
        ├─ faq-sctn      — 8 FAQ <details>
        └─ map-sctn      — banner img + title + Google Map iframe
   JSON-LD = live Yoast @graph (Layout) + FinancialService + FAQPage + Reviews
   (verbatim) + a city Service node per task spec.
   ----------------------------------------------------------------------- */
import Layout from "../layouts/Layout.astro";
import { SITE_URL, contact, replyMethods } from "../config/site";
import googleGLogoSvg from "../../reference/google-g-logo-svg.html?raw";
import financialServiceSchema from "../../reference/home-financialservice-schema.json";
import faqSchema from "../../reference/_ld-fountain-hills-business-broker-faq.json";
import reviewsSchema from "../../reference/_ld-fountain-hills-business-broker-reviews.json";

