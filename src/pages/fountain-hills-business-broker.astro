/* ---------- Page JSON-LD ---------- */
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${SITE_URL}/fountain-hills-business-broker/`,
  url: `${SITE_URL}/fountain-hills-business-broker/`,
  name: pageTitle,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  primaryImageOfPage: { "@id": `${SITE_URL}/fountain-hills-business-broker/#primaryimage` },
  image: { "@id": `${SITE_URL}/fountain-hills-business-broker/#primaryimage` },
  thumbnailUrl: ogImage,
  datePublished: "2024-03-08T21:19:44+00:00",
  dateModified: "2026-06-12T21:34:36+00:00",
  description: pageDescription,
  breadcrumb: { "@id": `${SITE_URL}/fountain-hills-business-broker/#breadcrumb` },
  inLanguage: "en-US",
  potentialAction: [{ "@type": "ReadAction", target: [`${SITE_URL}/fountain-hills-business-broker/`] }],
};

const primaryImageSchema = {
  "@type": "ImageObject",
  inLanguage: "en-US",
  "@id": `${SITE_URL}/fountain-hills-business-broker/#primaryimage`,
  url: ogImage,
  contentUrl: ogImage,
  width: 1200,
  height: 1200,
  caption: `Fountain Hills Business Broker ${SITE_URL}/`,
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${SITE_URL}/fountain-hills-business-broker/#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "AZ Business Broker", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Fountain Hills Business Broker" },
  ],
};

const serviceSchema = {
  "@type": "Service",
  "@id": `${SITE_URL}/fountain-hills-business-broker/#service`,
  name: "Fountain Hills Business Broker",
  serviceType: "Business Brokerage — Selling a Business in Fountain Hills",
  description: pageDescription,
  areaServed: { "@type": "City", name: "Fountain Hills", containedInPlace: { "@type": "State", name: "Arizona" } },
  provider: {
    "@type": "ProfessionalService",
    name: "Phil Reese, Arizona Business Broker",
    "@id": `${SITE_URL}/`,
    url: `${SITE_URL}/`,
  },
};

const structuredData = [
  { "@context": "https://schema.org", "@graph": [webPageSchema, primaryImageSchema, breadcrumbSchema, serviceSchema] },
  financialServiceSchema,
  faqSchema,
  reviewsSchema,
];

/* ---------- Reviews (test-sctn-alt), verbatim ---------- */
const reviews = [
  { text: "If you have ever bought or sold a company, you know that it's an incredibly complex endeavor, sometimes with many unexpected twists and turns along the way. The smart person soon learns this is not something you should take on without the help of an expert to guide you. Phil Reese may well be the best and brightest expert you can find. Phil was amazing to work with throughout the entire process of selling our company. He was always highly professional and available to answer every kind of question or concern. We really don't know how we could have gotten through the tedious, roller-coaster process without him. And best of all, his guidance assured us the best possible results with an excellent buyer and top-level offer at the end of the day. We highly recommend Phil Reese!", name: "Mike Williams", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURXdFpxSzJnRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDWtZqK2gE%7CCgwI0PaSkgYQoI3VtgE%7C?hl=en-US" },
  { text: "To anyone looking to buy or sell a business, do yourself a HUGE favor and use the services of Phil Reese! We had used other business brokers in the past and had less than desired results. In 2015 Phil listed and sold our multi-million dollar business in 6 months. His knowledge, support, enthusiasm, professionalism and his personalized service is outstanding! Listing our business with Phil was absolutely the best decision we could have made! We love him and so will you! Mark and Juanita Wdowiak", name: "Mark Wdowiak", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURRbDRucmdRRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDQl4nrgQE%7CCgwI04_q0gUQwJ6YuwI%7C?hl=en-US" },
  { text: "We used Phil to close on a business in Phoenix, AZ. He understood what we were looking for and was very accommodating to both us and the Seller. Everything went so smoothly, we closed in 3 weeks. I would highly recommend Phil.", name: "Tonia Khouri", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUR5enFmNHd3RRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDyzqf4wwE%7CCgoIzvSUggYQ-Iht%7C?hl=en-US" },
  { text: "Highly recommend Phil he’s the best at finding you the right buyer for your business. Always available to answer your questions promptly returns calls! Knows the laws and trustworthy.", name: "Valerie Mapua", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VNcjE0S1R4b01iSFNREAE!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEMr14KTxoMbHSQ%7CCgwI3PLIwQYQ-L3K4QI%7C?hl=en-US" },
  { text: "I had a question regarding my business, and Phil was very kind, taking his time to converse with me, even though I didn't use his service. He was awesome, and I will definitely keep his information and refer him to clients. A very professional gentleman.", name: "karen benedek", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSURqdy1EanZ3RRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDjw-DjvwE%7CCgwI9r3lsQYQiMry2wI%7C?hl=en-US" },
  { text: "Phil was very professional in facilitating our transaction. He knew what he was doing and is quite competent in following through with documenting the transaction and keeping all parties to the deal on track. I'd recommend him to anyone seeking a competent business broker.", name: "Doug L", url: "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUR3M082MDJnRRAB!2m1!1s0x0:0xd59527a5c7d15195!3m1!1s2@1:CIHM0ogKEICAgIDw3O602gE%7CCgwI4cuJ3gUQ2KC98wI%7C?hl=en-US" },
];

/* ---------- "What Does A CBI Do" (philo-sctn), verbatim ---------- */
const philoParas = [
  "As a proud member of the Arizona Business Brokers Association (AZBBA), I embrace the opportunity to collaborate with fellow members. This collaboration significantly broadens the pool of potential buyers, improving the opportunities of finding the perfect match for your business. What’s more, I’m honored to be recognized as an award-winning agent, standing as one of the most highly qualified professionals in my field.",
  "My credentials speak volumes about my expertise and dedication. As a Certified Business Intermediary (CBI), a distinction held by only a select few in Arizona—just eight, to be precise—I’ve undergone rigorous testing mandated by the International Business Brokers Association. This certification attests to my comprehensive knowledge and extensive experience in facilitating business sales, providing you with the assurance of working with a seasoned professional.",
  "In affiliation with West USA Realty, boasting the largest Business Broker group in Arizona, your business listing is guaranteed maximum exposure within the local market.",
];

