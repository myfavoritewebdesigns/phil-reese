const areaLinks = [
  { href: "/phoenix-business-broker/", label: "Phoenix Business Broker" },
  { href: "/scottsdale-business-broker/", label: "Scottsdale Business Broker" },
  { href: "/tempe-business-broker/", label: "Tempe Business Broker" },
