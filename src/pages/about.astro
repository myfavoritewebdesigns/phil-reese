/* Person schema — Phil + every office as a workLocation Place */
function officePlace(o: (typeof offices)[number]) {
  const [locality, regionZip = ""] = o.cityLine.split(/,\s*/);
  const [region = "AZ", postalCode = ""] = regionZip.trim().split(/\s+/);
  return {
    "@type": "Place",
    name: o.title,
    telephone: o.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: o.street.replace(/,$/, ""),
      addressLocality: locality,
      addressRegion: region,
      postalCode,
      addressCountry: "US",
    },
  };
}

const personSchema = {
  "@type": "Person",
  "@id": `${SITE_URL}/#person`,
  name: "Phil Reese",
  jobTitle: "Arizona Business Broker",
  honorificSuffix: "MCBI",
  description:
    "Master Certified Business Intermediary (MCBI) and former Ethics Chairman of the Arizona Business Brokers Association (AZBBA), helping Arizona business owners sell their companies since 2001.",
